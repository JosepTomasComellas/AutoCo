@inject ApiClient Api
@inject UserStateService UserState

<MudDialog Style="min-width:600px">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@ActivityName</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @ClassName @(ClassAcademicYear is not null ? $"({ClassAcademicYear})" : "")
                </MudText>
            </MudStack>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-4" />
        }
        else if (_chart is null)
        {
            <MudAlert Severity="Severity.Warning">No hi ha dades d'avaluació.</MudAlert>
        }
        else if (!_chart.Groups.Any(g => g.AvgAutoEval.HasValue || g.AvgCoEval.HasValue))
        {
            <MudAlert Severity="Severity.Info">
                Encara no hi ha avaluacions enviades per a aquesta activitat.
            </MudAlert>
        }
        else
        {
            <!-- Resum global: Auto vs Co per grup -->
            <MudText Typo="Typo.subtitle2" Class="mb-2">
                Nota mitjana Auto-eval i Co-eval per grup
            </MudText>
            <MudChart ChartType="ChartType.Bar"
                      ChartSeries="@_globalSeries"
                      XAxisLabels="@_groupLabels"
                      ChartOptions="@_opts"
                      Width="100%" Height="220px" Class="mb-2" />

            <MudStack Row="true" Justify="Justify.Center" Spacing="3" Class="mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <div style="width:12px;height:12px;border-radius:2px;background:#1976d2"></div>
                    <MudText Typo="Typo.caption">Auto-eval</MudText>
                </MudStack>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <div style="width:12px;height:12px;border-radius:2px;background:#ef6c00"></div>
                    <MudText Typo="Typo.caption">Co-eval</MudText>
                </MudStack>
            </MudStack>

            <!-- Detall per criteri amb tab per cada un -->
            <MudDivider Class="mb-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Detall per criteri</MudText>
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-3">
                @foreach (var c in _chart.CriteriaDetail)
                {
                    var series  = CriteriaSeries(c);
                    var cLabel  = c.CriteriaLabel;
                    <MudTabPanel Text="@ShortLabel(cLabel)">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@cLabel</MudText>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@series"
                                  XAxisLabels="@_groupLabels"
                                  ChartOptions="@_opts"
                                  Width="100%" Height="180px" />
                    </MudTabPanel>
                }
            </MudTabs>

            <!-- Taula resum -->
            <MudDivider Class="my-3" />
            <MudSimpleTable Dense="true" Hover="true">
                <thead>
                    <tr>
                        <th>Grup</th>
                        <th style="text-align:center">Alumnes</th>
                        <th style="text-align:center">Auto-eval</th>
                        <th style="text-align:center">Co-eval</th>
                        <th style="text-align:center">Diferència</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in _chart.Groups)
                    {
                        var diff = g.AvgAutoEval.HasValue && g.AvgCoEval.HasValue
                            ? (double?)(g.AvgAutoEval.Value - g.AvgCoEval.Value) : null;
                        var diffColor = diff.HasValue
                            ? (diff > 0.5 ? "color:var(--mud-palette-warning-text)"
                             : diff < -0.5 ? "color:var(--mud-palette-error-text)"
                             : "color:var(--mud-palette-success-text)") : "";
                        <tr>
                            <td><strong>@g.GroupName</strong></td>
                            <td style="text-align:center">
                                @g.NumStudentsTotal
                                @if (g.NumStudentsWithAuto < g.NumStudentsTotal)
                                {
                                    <MudTooltip Text="@($"{g.NumStudentsWithAuto}/{g.NumStudentsTotal} han completat l'autoavaluació")">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning"
                                                 Size="Size.Small" Color="Color.Warning" />
                                    </MudTooltip>
                                }
                            </td>
                            <td style="text-align:center">
                                @(g.AvgAutoEval.HasValue ? g.AvgAutoEval.Value.ToString("F1") : "–")
                            </td>
                            <td style="text-align:center">
                                @(g.AvgCoEval.HasValue ? g.AvgCoEval.Value.ToString("F1") : "–")
                            </td>
                            <td style="text-align:center;@diffColor;font-weight:600">
                                @(diff.HasValue ? (diff > 0 ? "+" : "") + diff.Value.ToString("F1") : "–")
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Close()">Tancar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int    ActivityId        { get; set; }
    [Parameter] public string ActivityName      { get; set; } = "";
    [Parameter] public string ClassName         { get; set; } = "";
    [Parameter] public string? ClassAcademicYear { get; set; }

    private ActivityChartDto? _chart;
    private bool _loading = true;

    private string[]         _groupLabels  = [];
    private List<ChartSeries> _globalSeries = [];

    private readonly ChartOptions _opts = new()
    {
        YAxisTicks    = 2,
        MaxNumYAxisTicks = 5,
        YAxisRequireZeroPoint = true,
        ChartPalette  = ["#1976d2", "#ef6c00"]
    };

    protected override async Task OnInitializedAsync()
    {
        Api.SetToken(UserState.Token!);
        _chart = await Api.GetChartAsync(ActivityId);
        if (_chart is not null)
            BuildChartData();
        _loading = false;
    }

    private void BuildChartData()
    {
        _groupLabels = _chart!.Groups.Select(g => g.GroupName).ToArray();

        _globalSeries =
        [
            new ChartSeries
            {
                Name = "Auto-eval",
                Data = _chart.Groups.Select(g => g.AvgAutoEval ?? 0d).ToArray()
            },
            new ChartSeries
            {
                Name = "Co-eval",
                Data = _chart.Groups.Select(g => g.AvgCoEval ?? 0d).ToArray()
            }
        ];
    }

    private List<ChartSeries> CriteriaSeries(CriteriaGroupChartDto c) =>
    [
        new ChartSeries
        {
            Name = "Auto-eval",
            Data = c.Groups.Select(g => g.AvgAuto ?? 0d).ToArray()
        },
        new ChartSeries
        {
            Name = "Co-eval",
            Data = c.Groups.Select(g => g.AvgCo ?? 0d).ToArray()
        }
    ];

    private static string ShortLabel(string label) =>
        label.Length > 12 ? label[..12] + "…" : label;
}
