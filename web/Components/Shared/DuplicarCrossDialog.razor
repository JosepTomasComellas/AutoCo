@inject ApiClient Api
@inject UserStateService UserState

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            Es crearà una nova activitat a un altre mòdul/classe, amb els mateixos grups (sense alumnes assignats).
        </MudText>

        <MudSelect T="int" Value="_classeId" Label="Classe destí"
                   Variant="Variant.Outlined" Class="mb-3"
                   AnchorOrigin="Origin.BottomCenter"
                   ValueChanged="OnClasseChanged">
            @foreach (var c in _classes)
            {
                <MudSelectItem T="int" Value="@c.Id">
                    @c.Name@(c.AcademicYear is not null ? $" ({c.AcademicYear})" : "")
                </MudSelectItem>
            }
        </MudSelect>

        @if (_loadingModuls)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }
        else if (_moduls.Any())
        {
            <MudSelect T="int" @bind-Value="_modulId" Label="Mòdul destí"
                       Variant="Variant.Outlined" Class="mb-3"
                       AnchorOrigin="Origin.BottomCenter">
                @foreach (var m in _moduls)
                {
                    <MudSelectItem T="int" Value="@m.Id">@m.Code – @m.Name</MudSelectItem>
                }
            </MudSelect>
        }
        else if (_classeId != 0)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                Aquesta classe no té mòduls.
            </MudAlert>
        }

        <MudTextField @bind-Value="_nom" Label="Nom de la nova activitat"
                      Variant="Variant.Outlined" Class="mb-3" Immediate="true" />
        <MudTextField @bind-Value="_desc" Label="Descripció (opcional)"
                      Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancel·lar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Confirm"
                   Disabled="@(_modulId == 0 || string.IsNullOrWhiteSpace(_nom))"
                   StartIcon="@Icons.Material.Filled.ContentCopy">
            Duplicar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string NomOriginal   { get; set; } = "";
    [Parameter] public int    CurrentClassId { get; set; }

    private List<ClassDto>  _classes      = [];
    private List<ModuleDto> _moduls       = [];
    private int    _classeId     = 0;
    private int    _modulId      = 0;
    private string _nom          = "";
    private string? _desc        = null;
    private bool   _loadingModuls = false;

    protected override async Task OnInitializedAsync()
    {
        Api.SetToken(UserState.Token!);
        _classes = await Api.GetClassesAsync() ?? [];
        _nom     = NomOriginal + " (còpia)";

        // Selecciona per defecte la mateixa classe si té mòduls
        var first = _classes.FirstOrDefault();
        if (first is not null)
            await OnClasseChanged(first.Id);
    }

    private async Task OnClasseChanged(int classeId)
    {
        _classeId     = classeId;
        _modulId      = 0;
        _loadingModuls = true;
        StateHasChanged();
        Api.SetToken(UserState.Token!);
        _moduls = await Api.GetModulesAsync(_classeId) ?? [];
        if (_moduls.Any()) _modulId = _moduls.First().Id;
        _loadingModuls = false;
    }

    private void Confirm()
    {
        if (_modulId == 0 || string.IsNullOrWhiteSpace(_nom)) return;
        MudDialog.Close(DialogResult.Ok(
            new DuplicateCrossRequest(_modulId, _nom.Trim(),
                string.IsNullOrWhiteSpace(_desc) ? null : _desc.Trim())));
    }
}
