@inject IStringLocalizer<SharedResources> Loc

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            @Loc["MoveDialog_Info"]
        </MudText>
        <MudSelect T="int" @bind-Value="_targetId" Label="@Loc["MoveDialog_TargetClass"]"
                   Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter">
            @foreach (var c in Classes)
            {
                <MudSelectItem T="int" Value="@c.Id">
                    @c.Name@(c.AcademicYear is not null ? $" ({c.AcademicYear})" : "")
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-1">
                        @Loc["MoveDialog_StudentCount", c.NumStudents]
                    </MudText>
                </MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">@Loc["Action_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="Confirm"
                   Disabled="_targetId == 0" StartIcon="@Icons.Material.Filled.DriveFileMove">
            @Loc["MoveDialog_Confirm"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public List<ClassDto> Classes { get; set; } = [];

    private int _targetId = 0;

    protected override void OnParametersSet()
    {
        if (_targetId == 0 && Classes.Any())
            _targetId = Classes.First().Id;
    }

    private void Confirm() => MudDialog.Close(DialogResult.Ok(_targetId));
}
