@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_nom" Label="Nom de l'activitat" Variant="Variant.Outlined"
                      Class="mb-3" Immediate="true" />
        <MudTextField @bind-Value="_desc" Label="Descripció (opcional)" Variant="Variant.Outlined"
                      Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel·lar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm"
                   Disabled="@string.IsNullOrWhiteSpace(_nom)">
            Desar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string  NomActual  { get; set; } = "";
    [Parameter] public string? DescActual { get; set; }

    private string  _nom  = "";
    private string? _desc;

    protected override void OnParametersSet()
    {
        _nom  = NomActual;
        _desc = DescActual;
    }

    private void Cancel() => MudDialog.Cancel();

    private void Confirm()
    {
        if (string.IsNullOrWhiteSpace(_nom)) return;
        MudDialog.Close(DialogResult.Ok((
            _nom.Trim(),
            string.IsNullOrWhiteSpace(_desc) ? null : _desc.Trim())));
    }
}
