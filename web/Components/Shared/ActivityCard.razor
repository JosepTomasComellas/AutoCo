@implements IDisposable
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ParticipationNotificationService ParticipationNotifier
@inject IStringLocalizer<SharedResources> Loc

<MudCard Elevation="@(Act.IsOpen ? 2 : 1)"
         Class="@($"activity-card{(Act.IsOpen ? "" : " activity-card--closed")}")">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.h6"
                         Style="@(Act.IsOpen ? "" : "color:var(--mud-palette-text-secondary)")">
                    @Act.Name
                </MudText>
                @if (!Act.IsOpen)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@Loc["Card_Closed"]</MudChip>
                }
            </MudStack>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @Act.ModuleCode – @Act.ModuleName · @Act.ClassName · @Act.ProfessorName
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    @if (Act.Description is not null)
    {
        <MudCardContent Class="pt-0">
            <MudText Typo="Typo.body2" Color="@(Act.IsOpen ? Color.Default : Color.Secondary)">
                @Act.Description
            </MudText>
        </MudCardContent>
    }
    <MudCardContent Class="pt-0 pb-0">
        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @Loc["Card_Groups", Act.NumGroups]
            </MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                @Loc["Card_Students", Act.NumStudents]
            </MudChip>
            @if (Act.IsOpen && _participation is not null)
            {
                <MudTooltip Text="@Loc["Card_EvalTooltip", _participation.Submitted, _participation.Total]">
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_participation.Submitted == _participation.Total && _participation.Total > 0
                                       ? Color.Success : Color.Warning)"
                             Variant="Variant.Filled">
                        @Loc["Card_Evaluated", _participation.Submitted, _participation.Total]
                    </MudChip>
                </MudTooltip>
            }
            else if (Act.IsOpen && _loadingParticipation)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
        </MudStack>
        @if (Act.IsOpen && _participation is not null && _participation.Total > 0)
        {
            <MudProgressLinear Value="@(100.0 * _participation.Submitted / _participation.Total)"
                               Color="@(_participation.Submitted == _participation.Total ? Color.Success : Color.Warning)"
                               Rounded="true" Size="Size.Small" Class="mt-2" />
        }
    </MudCardContent>
    <MudCardActions Style="flex-wrap:nowrap;align-items:center">
        <MudButton Size="Size.Small" Color="Color.Primary"
                   Href="@($"/professor/resultats/{Act.Id}")">
            @Loc["Card_Results"]
        </MudButton>
        <MudButton Size="Size.Small" Color="Color.Secondary"
                   Href="@($"/professor/grups/{Act.Id}")">
            @Loc["Card_Groups2"]
        </MudButton>
        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default"
                       title="@Loc["Card_EditActivity"]"
                       OnClick="EditarAsync" />
        <MudIconButton Icon="@Icons.Material.Filled.BarChart" Color="Color.Primary"
                       title="@Loc["Card_ViewChart"]"
                       OnClick="ShowChartAsync" />
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Default"
                 title="@Loc["Card_MoreActions"]"
                 AnchorOrigin="Origin.BottomRight"
                 Dense="true">
            <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy"
                         OnClick="DuplicarAsync">
                @Loc["Card_DuplicateSame"]
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.CopyAll"
                         OnClick="DuplicarCrossAsync">
                @Loc["Card_DuplicateCross"]
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Tune"
                         OnClick="ManageCriteriaAsync">
                @Loc["Card_ManageCriteria"]
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.BookmarkAdd"
                         OnClick="SaveAsTemplateAsync">
                @Loc["Card_SaveAsTemplate"]
            </MudMenuItem>
            @if (Act.IsOpen)
            {
                <MudMenuItem Icon="@Icons.Material.Filled.Campaign"
                             OnClick="OpenInviteDialogAsync">
                    @Loc["Card_Invite"]
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.NotificationsActive"
                             OnClick="OpenRemindDialogAsync">
                    @Loc["Card_SendReminders"]
                </MudMenuItem>
            }
            <MudMenuItem Icon="@(Act.IsOpen ? Icons.Material.Filled.Lock : Icons.Material.Filled.LockOpen)"
                         IconColor="@(Act.IsOpen ? Color.Warning : Color.Success)"
                         OnClick="ToggleAsync">
                @(Act.IsOpen ? Loc["Card_CloseActivity"].Value : Loc["Card_OpenActivity"].Value)
            </MudMenuItem>
            <MudDivider />
            <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                         OnClick="DeleteAsync">
                <MudText Color="Color.Error">@Loc["Card_Delete"]</MudText>
            </MudMenuItem>
        </MudMenu>
    </MudCardActions>
</MudCard>

<!-- Diàleg d'enviament de missatges (invitació i recordatori) -->
<MudDialog @bind-IsOpen="_emailDialogOpen" Options="_emailDialogOpts">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@(_emailIsInvite ? Icons.Material.Filled.Campaign : Icons.Material.Filled.NotificationsActive)"
                     Size="Size.Small" />
            <MudText Typo="Typo.h6">@_emailDialogTitle</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_emailPhase == "confirm")
        {
            @if (_emailTargets.Count == 0)
            {
                <MudText>@Loc[_emailIsInvite ? "Card_InviteNoTargets" : "Card_RemindNoTargets"]</MudText>
            }
            else
            {
                <MudText Class="mb-3">
                    @Loc[_emailIsInvite ? "Card_InviteInfo" : "Card_RemindersInfo2", _emailTargets.Count]
                </MudText>
                @if (_emailIsInvite)
                {
                    <MudCheckBox @bind-Value="_emailIncludePwd" Color="Color.Primary"
                                 Label="@Loc["Card_InviteIncludePwd"]" />
                }
            }
        }
        else if (_emailPhase == "sending")
        {
            <MudStack Spacing="2">
                <MudProgressLinear Value="_emailProgress" Max="_emailTargets.Count"
                                   Color="Color.Primary" Rounded="true" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                    @Loc["Card_EmailSendingProgress", _emailProgress, _emailTargets.Count]
                </MudText>
                @if (!string.IsNullOrEmpty(_emailCurrent))
                {
                    <MudText Typo="Typo.body2" Align="Align.Center">@_emailCurrent</MudText>
                }
            </MudStack>
        }
        else
        {
            <MudStack Spacing="1">
                @if (_emailSent > 0)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle"
                             Color="Color.Success" Size="Size.Small">
                        @Loc["Card_EmailSent", _emailSent]
                    </MudChip>
                }
                @if (_emailSkipped > 0)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.Error"
                             Color="Color.Error" Size="Size.Small">
                        @Loc["Card_EmailErrors", _emailSkipped]
                    </MudChip>
                }
                @if (_emailSent == 0 && _emailSkipped == 0)
                {
                    <MudText>@Loc["Card_AllEvaluated"]</MudText>
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (_emailPhase == "confirm")
        {
            <MudButton OnClick="() => _emailDialogOpen = false">@Loc["Action_Cancel"]</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="StartEmailSendAsync"
                       Disabled="_emailTargets.Count == 0">
                @Loc["Action_Send"]
            </MudButton>
        }
        else if (_emailPhase == "done")
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="() => _emailDialogOpen = false">
                @Loc["Action_Close"]
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [Parameter, EditorRequired] public ActivityDto Act { get; set; } = default!;
    [Parameter] public EventCallback<ActivityDto>  OnUpdated { get; set; }
    [Parameter] public EventCallback<ActivityDto>  OnDeleted { get; set; }

    private ParticipationDto? _participation        = null;
    private bool              _loadingParticipation = false;
    private Func<ParticipationDto, Task>? _participationHandler;

    protected override async Task OnParametersSetAsync()
    {
        // Si l'activitat és oberta, càrrega inicial de participació
        if (Act.IsOpen && _participation is null && !_loadingParticipation)
            await LoadParticipationAsync();

        // Subscripció/desubscripció quan IsOpen canvia (p.ex. oberta des del dashboard)
        if (Act.IsOpen && _participationHandler is null)
            EnsureSubscribed();
        else if (!Act.IsOpen && _participationHandler is not null)
        {
            ParticipationNotifier.Unsubscribe(Act.Id, _participationHandler);
            _participationHandler = null;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || !Act.IsOpen) return;
        EnsureSubscribed();
    }

    private void EnsureSubscribed()
    {
        if (_participationHandler is not null) return; // ja subscrit
        _participationHandler = async dto =>
        {
            _participation = dto;
            await InvokeAsync(StateHasChanged);
        };
        ParticipationNotifier.Subscribe(Act.Id, _participationHandler);
    }

    private async Task LoadParticipationAsync()
    {
        _loadingParticipation = true;
        Api.SetToken(UserState.Token!);
        _participation        = await Api.GetParticipationAsync(Act.Id);
        _loadingParticipation = false;
    }

    public void Dispose()
    {
        if (_participationHandler is not null)
            ParticipationNotifier.Unsubscribe(Act.Id, _participationHandler);
    }

    private async Task ToggleAsync()
    {
        Api.SetToken(UserState.Token!);
        var updated = await Api.ToggleActivityAsync(Act.Id);
        if (updated is not null)
        {
            Snackbar.Add(updated.IsOpen ? Loc["Card_Opened"].Value : Loc["Card_ClosedMsg"].Value, Severity.Success);
            // La desubscripció/subscripció es gestiona a OnParametersSetAsync quan Act canvia
            await OnUpdated.InvokeAsync(updated);
        }
    }

    private async Task EditarAsync()
    {
        var parameters = new DialogParameters<EditarActivitatDialog>
        {
            { d => d.NomActual,  Act.Name },
            { d => d.DescActual, Act.Description }
        };
        var opts   = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialog.ShowAsync<EditarActivitatDialog>(Loc["Card_EditDialogTitle"].Value, parameters, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var (nom, desc) = ((string, string?))result.Data!;
        Api.SetToken(UserState.Token!);
        var updated = await Api.UpdateActivityAsync(Act.Id, new UpdateActivityRequest(nom, desc));
        if (updated is not null)
        {
            Snackbar.Add(Loc["Card_Updated"].Value, Severity.Success);
            await OnUpdated.InvokeAsync(updated);
        }
        else Snackbar.Add(Loc["Card_UpdateError"].Value, Severity.Error);
    }

    private async Task ShowChartAsync()
    {
        var parameters = new DialogParameters<GraficaActivitatDialog>
        {
            { d => d.ActivityId,        Act.Id },
            { d => d.ActivityName,      Act.Name },
            { d => d.ClassName,         Act.ClassName },
            { d => d.ClassAcademicYear, Act.ClassAcademicYear }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        await Dialog.ShowAsync<GraficaActivitatDialog>("", parameters, opts);
    }

    private async Task DuplicarAsync()
    {
        var parameters = new DialogParameters<DuplicarActivitatDialog>
        {
            { d => d.NomOriginal, Act.Name }
        };
        var opts   = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialog.ShowAsync<DuplicarActivitatDialog>(Loc["Card_DupDialogTitle"].Value, parameters, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var (nom, desc) = ((string, string?))result.Data!;
        Api.SetToken(UserState.Token!);
        var nova = await Api.DuplicateActivityAsync(Act.Id, new DuplicateActivityRequest(nom, desc));
        if (nova is not null)
        {
            Snackbar.Add(Loc["Card_DuplicateCreated", nova.Name].Value, Severity.Success);
            await OnUpdated.InvokeAsync(nova);
            Nav.NavigateTo($"/professor/grups/{nova.Id}");
        }
        else Snackbar.Add(Loc["Card_DuplicateError"].Value, Severity.Error);
    }

    private async Task DuplicarCrossAsync()
    {
        var parameters = new DialogParameters<DuplicarCrossDialog>
        {
            { d => d.NomOriginal,    Act.Name },
            { d => d.CurrentClassId, Act.ClassId }
        };
        var opts   = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await Dialog.ShowAsync<DuplicarCrossDialog>(Loc["Card_DupCrossTitle"].Value, parameters, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;

        var req = (DuplicateCrossRequest)result.Data!;
        Api.SetToken(UserState.Token!);
        var nova = await Api.DuplicateActivityCrossAsync(Act.Id, req);
        if (nova is not null)
        {
            Snackbar.Add(Loc["Card_DuplicateCrossCreated", nova.Name, nova.ClassName].Value, Severity.Success);
            await OnUpdated.InvokeAsync(nova);
            Nav.NavigateTo($"/professor/grups/{nova.Id}");
        }
        else Snackbar.Add(Loc["Card_DuplicateError"].Value, Severity.Error);
    }

    private async Task ManageCriteriaAsync()
    {
        var parameters = new DialogParameters<CriteriaDialog>
        {
            { d => d.ActivityId, Act.Id }
        };
        var opts = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        await Dialog.ShowAsync<CriteriaDialog>(Loc["Card_ManageCriteria"].Value, parameters, opts);
    }

    private async Task SaveAsTemplateAsync()
    {
        Api.SetToken(UserState.Token!);
        // Llegir els criteris actuals de l'activitat
        var criteria = await Api.GetActivityCriteriaAsync(Act.Id) ?? [];
        var items    = criteria.Select(c => new CriterionItem(c.Key, c.Label)).ToList();
        var req      = new CreateTemplateRequest(Act.Name, Act.Description, items);
        var saved    = await Api.CreateTemplateAsync(req);
        if (saved is not null)
            Snackbar.Add(Loc["Card_TemplateSaved", saved.Name].Value, Severity.Success);
        else
            Snackbar.Add(Loc["Card_TemplateError"].Value, Severity.Error);
    }

    // ── Diàleg d'enviament de missatges ─────────────────────────────────────
    private bool   _emailDialogOpen = false;
    private string _emailDialogTitle = "";
    private bool   _emailIsInvite   = false;
    private bool   _emailIncludePwd = false;
    private List<InviteTargetDto> _emailTargets = [];
    private int    _emailSent     = 0;
    private int    _emailSkipped  = 0;
    private int    _emailProgress = 0;
    private string _emailCurrent  = "";
    private string _emailPhase    = "confirm"; // confirm | sending | done
    private static readonly DialogOptions _emailDialogOpts = new()
        { MaxWidth = MaxWidth.Small, FullWidth = true };

    private async Task OpenInviteDialogAsync()
    {
        Api.SetToken(UserState.Token!);
        _emailTargets   = await Api.GetInviteTargetsAsync(Act.Id) ?? [];
        _emailIsInvite  = true;
        _emailIncludePwd = false;
        ResetEmailState();
        _emailDialogTitle = Loc["Card_InviteTitle"].Value;
        _emailDialogOpen  = true;
    }

    private async Task OpenRemindDialogAsync()
    {
        Api.SetToken(UserState.Token!);
        _emailTargets  = await Api.GetRemindTargetsAsync(Act.Id) ?? [];
        _emailIsInvite = false;
        ResetEmailState();
        _emailDialogTitle = Loc["Card_RemindersTitle"].Value;
        _emailDialogOpen  = true;
    }

    private void ResetEmailState()
    {
        _emailSent = _emailSkipped = _emailProgress = 0;
        _emailCurrent = "";
        _emailPhase   = "confirm";
    }

    private async Task StartEmailSendAsync()
    {
        _emailPhase = "sending";
        StateHasChanged();

        foreach (var target in _emailTargets)
        {
            _emailCurrent = target.NomComplet;
            StateHasChanged();
            bool sent = _emailIsInvite
                ? await Api.InviteOneAsync(Act.Id, target.StudentId, _emailIncludePwd)
                : await Api.RemindOneAsync(Act.Id, target.StudentId);
            if (sent) _emailSent++; else _emailSkipped++;
            _emailProgress++;
            StateHasChanged();
        }

        _emailPhase = "done";
        StateHasChanged();
    }

    private async Task DeleteAsync()
    {
        if (!await DeleteWithUndoAsync(Loc["Card_Deleting", Act.Name].Value)) return;
        Api.SetToken(UserState.Token!);
        await Api.DeleteActivityAsync(Act.Id);
        Snackbar.Add(Loc["Card_Deleted"].Value, Severity.Success);
        await OnDeleted.InvokeAsync(Act);
    }

    private async Task<bool> DeleteWithUndoAsync(string msg)
    {
        var cancelled = false;
        var cts = new CancellationTokenSource();
        Snackbar.Add(msg, Severity.Warning, cfg =>
        {
            cfg.Action               = Loc["Card_Undo"].Value;
            cfg.ActionColor          = Color.Warning;
            cfg.ActionVariant        = Variant.Text;
            cfg.OnClick              = _ => { cancelled = true; cts.Cancel(); return Task.CompletedTask; };
            cfg.VisibleStateDuration = 5000;
        });
        try { await Task.Delay(5500, cts.Token); } catch (OperationCanceledException) { }
        if (cancelled) Snackbar.Add(Loc["Card_UndoDeleted"].Value, Severity.Info);
        return !cancelled;
    }
}
