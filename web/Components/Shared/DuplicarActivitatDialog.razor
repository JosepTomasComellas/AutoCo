@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
            @Loc["DupDialog_Info", NomOriginal]
        </MudText>
        <MudTextField @bind-Value="_nom" Label="@Loc["DupDialog_NewName"]" Variant="Variant.Outlined"
                      Class="mb-3" Immediate="true" />
        <MudTextField @bind-Value="_desc" Label="@Loc["DupDialog_Description"]" Variant="Variant.Outlined"
                      Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Loc["Action_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Confirm"
                   Disabled="@string.IsNullOrWhiteSpace(_nom)">
            @Loc["DupDialog_Confirm"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string NomOriginal { get; set; } = "";

    private string  _nom  = "";
    private string? _desc = null;

    private void Cancel()  => MudDialog.Cancel();
    private void Confirm()
    {
        if (string.IsNullOrWhiteSpace(_nom)) return;
        MudDialog.Close(DialogResult.Ok((_nom.Trim(), string.IsNullOrWhiteSpace(_desc) ? null : _desc.Trim())));
    }
}
