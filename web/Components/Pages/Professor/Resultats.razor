@page "/professor/resultats/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Resultats – AutoCo</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard" Variant="Variant.Text">
        Tauler
    </MudButton>
    @if (_results is not null)
    {
        <MudText Typo="Typo.h5">@_results.Activity.Name</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@_results.Activity.ClassName</MudChip>
    }
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary"
                   title="Actualitzar" OnClick="LoadAsync" />
    @if (_results is not null)
    {
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.BarChart"
                   Href="@($"/professor/grafic/{ActivityId}")">
            Gràfic
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Download"
                   Href="@($"/professor/export-csv/{ActivityId}")">
            CSV
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Print"
                   OnClick="PrintAsync">
            PDF
        </MudButton>
    }
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_results is null)
{
    <MudAlert Severity="Severity.Error">Activitat no trobada o sense permisos.</MudAlert>
}
else if (!_results.Students.Any())
{
    <MudAlert Severity="Severity.Info">Encara no hi ha avaluacions.</MudAlert>
}
else
{
    var totalAlumnes = _results.Students.Count;
    var ambCoaval    = _results.Students.Count(s => s.NumPeerEvaluators > 0);
    var pctCompletat = totalAlumnes > 0 ? (double)ambCoaval / totalAlumnes * 100 : 0;
    var totCompletat = ambCoaval == totalAlumnes;

    <!-- Barra de progrés -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
        <MudProgressLinear Value="pctCompletat" Color="@(totCompletat ? Color.Success : Color.Primary)"
                           Rounded="true" Style="flex:1;height:8px" />
        <MudText Typo="Typo.caption" Color="@(totCompletat ? Color.Success : Color.Secondary)">
            @ambCoaval / @totalAlumnes avaluats (@pctCompletat.ToString("F0")%)
        </MudText>
    </MudStack>

    <!-- Filtres avançats -->
    <MudExpansionPanels Class="mb-4">
        <MudExpansionPanel Text="Filtres avançats" Icon="@Icons.Material.Filled.FilterList">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="_filterGroup" Label="Grup" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem T="string" Value='""'>Tots els grups</MudSelectItem>
                        @foreach (var g in _results.Students.Select(s => s.GroupName).Distinct().Order())
                        {
                            <MudSelectItem T="string" Value="@g">@g</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" @bind-Value="_filterGrade" Label="Rang de nota (coaval.)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                        <MudSelectItem T="string" Value='""'>Tots els rangs</MudSelectItem>
                        <MudSelectItem T="string" Value='"high"'>Alta (≥ 8)</MudSelectItem>
                        <MudSelectItem T="string" Value='"mid"'>Mitjana (5 – 7.9)</MudSelectItem>
                        <MudSelectItem T="string" Value='"low"'>Baixa (&lt; 5)</MudSelectItem>
                        <MudSelectItem T="string" Value='"none"'>Sense coavaluació</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                    <MudSwitch @bind-Value="_showNotes" Color="Color.Primary"
                               Label="Mostrar notes" Size="Size.Small" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_filteredStudents.Count de @totalAlumnes alumnes
                    </MudText>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>

    <!-- Taula principal -->
    <MudDataGrid T="StudentResultDto" Items="_filteredStudents" Dense="true" Hover="true"
                 SortMode="SortMode.Single" FixedHeader="true" Height="520px" Class="mb-6">
        <Columns>
            <TemplateColumn Title="#">
                <HeaderTemplate>
                    <MudTooltip Text="Núm. de llista" Placement="Placement.Top">
                        <span style="cursor:help">#</span>
                    </MudTooltip>
                </HeaderTemplate>
                <CellTemplate>@context.Item.NumLlista</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Cognoms, Nom" Sortable="true">
                <CellTemplate>@context.Item.Cognoms, @context.Item.Nom</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="s => s.GroupName" Title="Grup" Sortable="true" />
            @foreach (var c in _results.Criteria)
            {
                var key = c.Key;
                var label = c.Label;
                <TemplateColumn Title="@label">
                    <HeaderTemplate>
                        <MudText Typo="Typo.caption" Style="white-space:normal;text-align:center">
                            @label<br/><small>Auto / Co</small>
                        </MudText>
                    </HeaderTemplate>
                    <CellTemplate>
                        @{
                            var hasAuto = context.Item.SelfScores.TryGetValue(key, out var av) && av.HasValue;
                            var hasCo   = context.Item.AvgCoScores.TryGetValue(key, out var cv) && cv.HasValue;
                            var autoVal = hasAuto ? av!.Value.ToString("G")  : "–";
                            var coVal   = hasCo   ? cv!.Value.ToString("F1") : "–";
                            var autoCss = hasAuto ? GradeClass(av!.Value) : "grade-none";
                            var coCss   = hasCo   ? GradeClass(cv!.Value) : "grade-none";
                        }
                        <span class="@autoCss">@autoVal</span>
                        <span style="color:var(--mud-palette-text-disabled)">/</span>
                        <span class="@coCss">@coVal</span>
                    </CellTemplate>
                </TemplateColumn>
            }
            <TemplateColumn Title="Autoaval." Sortable="true"
                            SortBy='(StudentResultDto s) => s.AutAvgGlobal ?? -1'>
                <HeaderTemplate>
                    <MudTooltip Text="Nota global d'autoavaluació" Placement="Placement.Top">
                        <span style="cursor:help">Autoaval.</span>
                    </MudTooltip>
                </HeaderTemplate>
                <CellTemplate>
                    @{
                        var autGlobal = context.Item.AutAvgGlobal;
                        var autCss    = autGlobal.HasValue ? GradeClass(autGlobal.Value) : "grade-none";
                    }
                    <span class="@autCss" style="font-size:.95rem">
                        @(autGlobal.HasValue ? autGlobal.Value.ToString("F1") : "–")
                    </span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Coaval." Sortable="true"
                            SortBy='(StudentResultDto s) => s.AvgGlobal ?? -1'>
                <HeaderTemplate>
                    <MudTooltip Text="Nota global de coavaluació (mitjana de companys)" Placement="Placement.Top">
                        <span style="cursor:help">Coaval.</span>
                    </MudTooltip>
                </HeaderTemplate>
                <CellTemplate>
                    @{
                        var coGlobal = context.Item.AvgGlobal;
                        var coGCss   = coGlobal.HasValue ? GradeClass(coGlobal.Value) : "grade-none";
                    }
                    <span class="@coGCss" style="font-size:.95rem">
                        @(coGlobal.HasValue ? coGlobal.Value.ToString("F1") : "–")
                    </span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Coavs.">
                <HeaderTemplate>
                    <MudTooltip Text="Nombre de companys que han avaluat aquest alumne" Placement="Placement.Top">
                        <span style="cursor:help">Coavs.</span>
                    </MudTooltip>
                </HeaderTemplate>
                <CellTemplate>@context.Item.NumPeerEvaluators</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="s => s.SelfComment" Title="Comentari alumne" />
            @if (_showNotes)
            {
                <TemplateColumn Title="Nota professor">
                    <CellTemplate>
                        @{
                            var sid  = context.Item.StudentId;
                            var note = _notes.GetValueOrDefault(sid, "");
                            var edit = _editingNote == sid;
                        }
                        @if (edit)
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudTextField @bind-Value="_editNoteText"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              Style="min-width:180px" Immediate="true"
                                              Placeholder="Nota del professor..." />
                                <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success"
                                               Size="Size.Small" OnClick="() => SaveNoteAsync(sid)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Default"
                                               Size="Size.Small" OnClick="CancelNoteEdit" />
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.body2"
                                         Style="@(string.IsNullOrEmpty(note) ? "color:var(--mud-palette-text-disabled)" : "")">
                                    @(string.IsNullOrEmpty(note) ? "—" : note)
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default"
                                               Size="Size.Small" OnClick="() => StartNoteEdit(sid, note)" />
                            </MudStack>
                        }
                    </CellTemplate>
                </TemplateColumn>
            }
        </Columns>
    </MudDataGrid>

    <!-- Detall coavaluacions -->
    <MudText Typo="Typo.h6" Class="mb-3">Detall coavaluacions</MudText>
    @foreach (var s in _filteredStudents.Where(x => x.PeerEvaluations.Any()))
    {
        var sid = s.StudentId;
        <MudExpansionPanel Class="mb-1">
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
                    <MudText Typo="Typo.body1">@s.Cognoms, @s.Nom (@s.GroupName)</MudText>
                    <MudSpacer />
                    <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Primary"
                                   Size="Size.Small" title="Informe individual"
                                   Href="@($"/professor/informe/{ActivityId}/{sid}")"
                                   @onclick:stopPropagation="true" />
                </MudStack>
            </TitleContent>
            <ChildContent>
            <MudDataGrid T="PeerEvaluationDto" Items="s.PeerEvaluations" Dense="true">
                <Columns>
                    <PropertyColumn Property="p => p.EvaluatorName" Title="Avaluador/a" />
                    @foreach (var c in _results.Criteria)
                    {
                        var key = c.Key;
                        var label = c.Label;
                        <TemplateColumn Title="@label">
                            <CellTemplate>
                                @{
                                    var v = context.Item.Scores.TryGetValue(key, out var sv) ? (double?)sv : null;
                                    var css = v.HasValue ? GradeClass(v.Value) : "grade-none";
                                }
                                <span class="@css">@(v.HasValue ? v.Value.ToString("G") : "–")</span>
                            </CellTemplate>
                        </TemplateColumn>
                    }
                    <PropertyColumn Property="p => p.Comment" Title="Comentari" />
                </Columns>
            </MudDataGrid>
            </ChildContent>
        </MudExpansionPanel>
    }

    <!-- Registre d'activitat -->
    @if (_log.Any())
    {
        <MudDivider Class="my-6" />
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Class="mr-1" Style="vertical-align:middle" />
            Registre d'activitat
        </MudText>
        <MudSimpleTable Dense="true" Hover="true" Style="background:transparent;max-height:300px;overflow-y:auto">
            <thead>
                <tr>
                    <th>Data/hora</th>
                    <th>Acció</th>
                    <th>Actor</th>
                    <th>Detalls</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _log)
                {
                    <tr>
                        <td><MudText Typo="Typo.caption">@entry.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</MudText></td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="@LogColor(entry.Action)" Variant="Variant.Filled">
                                @LogLabel(entry.Action)
                            </MudChip>
                        </td>
                        <td><MudText Typo="Typo.body2">@(entry.ActorName ?? "—")</MudText></td>
                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@entry.Details</MudText></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    [Parameter] public int ActivityId { get; set; }

    private ActivityResultsDto?      _results = null;
    private bool                     _loading = true;
    private List<ActivityLogDto>     _log     = [];
    private Dictionary<int, string>  _notes   = [];

    // Filtres
    private string _filterGroup = "";
    private string _filterGrade = "";
    private bool   _showNotes   = false;

    // Edició de notes
    private int    _editingNote  = -1;
    private string _editNoteText = "";

    private List<StudentResultDto> _filteredStudents => _results?.Students
        .Where(s =>
            (string.IsNullOrEmpty(_filterGroup) || s.GroupName == _filterGroup) &&
            (_filterGrade switch
            {
                "high" => s.AvgGlobal >= 8,
                "mid"  => s.AvgGlobal is >= 5 and < 8,
                "low"  => s.AvgGlobal is < 5,
                "none" => !s.AvgGlobal.HasValue,
                _      => true
            }))
        .ToList() ?? [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (!UserState.IsProfessor) return;
        _loading = true;
        Api.SetToken(UserState.Token!);
        var resultsTask = Api.GetResultsAsync(ActivityId);
        var logTask     = Api.GetActivityLogAsync(ActivityId);
        var notesTask   = Api.GetNotesForActivityAsync(ActivityId);
        await Task.WhenAll(resultsTask, logTask, notesTask);
        _results = resultsTask.Result;
        _log     = logTask.Result     ?? [];
        _notes   = (notesTask.Result  ?? []).ToDictionary(n => n.StudentId, n => n.Note);
        _loading = false;
    }

    private void StartNoteEdit(int studentId, string current)
    {
        _editingNote  = studentId;
        _editNoteText = current;
    }

    private void CancelNoteEdit()
    {
        _editingNote  = -1;
        _editNoteText = "";
    }

    private async Task SaveNoteAsync(int studentId)
    {
        Api.SetToken(UserState.Token!);
        var saved = await Api.SaveNoteAsync(ActivityId, studentId, _editNoteText);
        if (saved is not null)
        {
            _notes[studentId] = saved.Note;
            Snackbar.Add("Nota desada.", Severity.Success);
        }
        CancelNoteEdit();
    }

    private static string GradeClass(double v) =>
        v >= 8 ? "grade-high" : v >= 5 ? "grade-mid" : "grade-low";

    private static Color LogColor(string action) => action switch
    {
        "created"   => Color.Primary,
        "opened"    => Color.Success,
        "closed"    => Color.Warning,
        "evaluated" => Color.Info,
        "deleted"   => Color.Error,
        _           => Color.Default
    };

    private static string LogLabel(string action) => action switch
    {
        "created"   => "Creada",
        "opened"    => "Oberta",
        "closed"    => "Tancada",
        "evaluated" => "Avaluació enviada",
        "deleted"   => "Esborrada",
        _           => action
    };

    private async Task PrintAsync() =>
        await JS.InvokeVoidAsync("window.print");
}
