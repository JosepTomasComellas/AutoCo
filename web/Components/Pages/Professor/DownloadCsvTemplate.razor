@page "/professor/download-csv-template"
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IJSRuntime JS

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

        var csv = "NumLlista;Nom;Cognoms;CorreuElectronic;PIN\n1;Maria;García;maria@escola.cat;\n2;Pere;López;;1234\n";
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(csv));
        await JS.InvokeVoidAsync("downloadBase64File", base64, "plantilla_alumnes.csv", "text/csv;charset=utf-8");
        Nav.NavigateTo(Nav.Uri.Contains("classId") ? Nav.Uri : "/professor/classes");
    }
}
