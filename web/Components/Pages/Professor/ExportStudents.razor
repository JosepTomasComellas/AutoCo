@page "/professor/export-students"
@inject NavigationManager Nav

<PageTitle>Redireccionant...</PageTitle>

@code {
    [SupplyParameterFromQuery] public int? ClassId { get; set; }

    protected override void OnInitialized()
    {
        Nav.NavigateTo(ClassId.HasValue ? $"/professor/alumnes/{ClassId}" : "/professor/classes");
    }
}
