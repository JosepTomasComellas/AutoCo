@page "/professor/export-csv/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> Loc

<PageTitle>Exportant CSV...</PageTitle>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
    <MudButton Href="/professor/dashboard" Class="mt-2">@Loc["ExportCsv_Back"]</MudButton>
}

@code {
    [Parameter] public int ActivityId { get; set; }
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

        Api.SetToken(UserState.Token!);
        var result = await Api.ExportCsvAsync(ActivityId);
        if (result is null) { _error = Loc["ExportCsv_Error"].Value; StateHasChanged(); return; }

        var (content, fileName) = result.Value;
        var base64 = Convert.ToBase64String(content);
        await JS.InvokeVoidAsync("downloadBase64File", base64, fileName, "text/csv;charset=utf-8");
        Nav.NavigateTo($"/professor/resultats/{ActivityId}");
    }
}
