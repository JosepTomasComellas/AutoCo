@page "/professor/perfil"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ProtectedLocalStorage LocalStorage

<PageTitle>El meu perfil – AutoCo</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">Tauler</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">El meu perfil</MudText>
</MudStack>

<MudContainer MaxWidth="MaxWidth.Small">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudCard Elevation="3">
            <MudCardContent>
                <!-- Info general -->
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:700">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                    Dades personals
                </MudText>

                <MudTextField @bind-Value="_nom" Label="Nom" Variant="Variant.Outlined"
                              Class="mb-3" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                <MudTextField @bind-Value="_cognoms" Label="Cognoms" Variant="Variant.Outlined"
                              Class="mb-3" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                <MudTextField Value="@_email" Label="Correu electrònic" Variant="Variant.Outlined"
                              Class="mb-5" ReadOnly="true" HelperText="El correu no és modificable."
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

                <MudDivider Class="mb-4" />

                <!-- Canvi de contrasenya -->
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:700">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                    Canvi de contrasenya (opcional)
                </MudText>

                <MudTextField @bind-Value="_currentPassword" Label="Contrasenya actual"
                              Variant="Variant.Outlined" Class="mb-3"
                              InputType="@_pwdTypeActual" Immediate="true"
                              Adornment="Adornment.End" AdornmentIcon="@_pwdIconActual"
                              OnAdornmentClick="() => _showActual = !_showActual"
                              HelperText="Necessari per canviar la contrasenya." />
                <MudTextField @bind-Value="_newPassword" Label="Nova contrasenya"
                              Variant="Variant.Outlined" Class="mb-3"
                              InputType="@_pwdTypeNova" Immediate="true"
                              Adornment="Adornment.End" AdornmentIcon="@_pwdIconNova"
                              OnAdornmentClick="() => _showNova = !_showNova"
                              HelperText="Mínim 8 caràcters." />
                <MudTextField @bind-Value="_confirmPassword" Label="Confirmar nova contrasenya"
                              Variant="Variant.Outlined" Class="mb-4"
                              InputType="InputType.Password" Immediate="true" />

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                }
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="SaveAsync" Disabled="_saving"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Desar canvis
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    private string _nom             = "";
    private string _cognoms         = "";
    private string _email           = "";
    private string _currentPassword = "";
    private string _newPassword     = "";
    private string _confirmPassword = "";
    private bool   _loading         = true;
    private bool   _saving          = false;
    private string? _error;

    private bool _showActual = false;
    private bool _showNova   = false;
    private InputType _pwdTypeActual => _showActual ? InputType.Text : InputType.Password;
    private InputType _pwdTypeNova   => _showNova   ? InputType.Text : InputType.Password;
    private string _pwdIconActual => _showActual ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string _pwdIconNova   => _showNova   ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        var prof = await Api.GetOwnProfileAsync();
        if (prof is null) { Nav.NavigateTo("/professor/dashboard"); return; }
        _nom     = prof.Nom;
        _cognoms = prof.Cognoms;
        _email   = prof.Email;
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = null;

        // Validació de contrasenya si s'omple
        if (!string.IsNullOrWhiteSpace(_newPassword) || !string.IsNullOrWhiteSpace(_currentPassword))
        {
            if (string.IsNullOrWhiteSpace(_currentPassword))
            { _error = "Has d'introduir la contrasenya actual per canviar-la."; return; }
            if (string.IsNullOrWhiteSpace(_newPassword))
            { _error = "Introdueix la nova contrasenya."; return; }
            if (_newPassword.Length < 8)
            { _error = "La nova contrasenya ha de tenir almenys 8 caràcters."; return; }
            if (_newPassword != _confirmPassword)
            { _error = "Les contrasenyes no coincideixen."; return; }
        }

        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms))
        { _error = "Nom i cognoms són obligatoris."; return; }

        _saving = true;
        Api.SetToken(UserState.Token!);
        var req = new UpdateOwnProfileRequest(
            _nom.Trim(), _cognoms.Trim(),
            string.IsNullOrWhiteSpace(_currentPassword) ? null : _currentPassword,
            string.IsNullOrWhiteSpace(_newPassword)     ? null : _newPassword);

        var result = await Api.UpdateOwnProfileAsync(req);
        _saving = false;

        if (result is null)
        {
            _error = "Error en desar. Comprova la contrasenya actual.";
        }
        else
        {
            // Actualitza la sessió amb el nou nom
            var session = new LoginResponse(UserState.Token!, result.NomComplet,
                UserState.Role!, result.Id);
            try { await LocalStorage.SetAsync("autoco_session", session); } catch { }
            UserState.SetLogin(session);

            _nom     = result.Nom;
            _cognoms = result.Cognoms;
            _currentPassword = "";
            _newPassword     = "";
            _confirmPassword = "";
            Snackbar.Add("Perfil actualitzat correctament.", Severity.Success);
        }
    }
}
