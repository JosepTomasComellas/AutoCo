@page "/professor/perfil"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ProtectedLocalStorage LocalStorage
@inject IStringLocalizer<SharedResources> Loc
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>El meu perfil – AutoCo</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">@Loc["Nav_Dashboard"]</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Primary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">@Loc["Profile_Title"]</MudText>
</MudStack>

<MudContainer MaxWidth="MaxWidth.Small">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudCard Elevation="3">
            <MudCardContent>
                <!-- Foto de perfil -->
                <MudStack AlignItems="AlignItems.Center" Class="mb-4">
                    <MudAvatar Style="width:96px;height:96px;margin:0 auto">
                        @if (UserState.FotoUrl is not null)
                        {
                            <MudImage Src="@($"{UserState.FotoUrl}?v={UserState.FotoVersion}")"
                                      Style="width:100%;height:100%;object-fit:cover" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.AccountCircle"
                                     Style="font-size:64px" />
                        }
                    </MudAvatar>
                    <MudStack Row="true" Spacing="1">
                        <MudFileUpload T="IBrowserFile" Accept=".jpg,.jpeg,.png,.webp"
                                       FilesChanged="UploadFotoAsync">
                            <ActivatorContent>
                                <MudButton StartIcon="@Icons.Material.Filled.CameraAlt"
                                           Variant="Variant.Outlined" Size="Size.Small">
                                    @Loc["Profile_ChangeFoto"]
                                </MudButton>
                            </ActivatorContent>
                        </MudFileUpload>
                        @if (UserState.FotoUrl is not null)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" title="@Loc["Profile_DeleteFoto"]"
                                           OnClick="DeleteFotoAsync" />
                        }
                    </MudStack>
                </MudStack>

                <MudDivider Class="mb-4" />

                <!-- Info general -->
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:700">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                    @Loc["Profile_PersonalData"]
                </MudText>

                <MudTextField @bind-Value="_nom" Label="@Loc["Label_Name"]" Variant="Variant.Outlined"
                              Class="mb-3" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                <MudTextField @bind-Value="_cognoms" Label="@Loc["Label_Surname"]" Variant="Variant.Outlined"
                              Class="mb-3" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                <MudTextField Value="@_email" Label="@Loc["Label_Email"]" Variant="Variant.Outlined"
                              Class="mb-5" ReadOnly="true" HelperText="@Loc["Profile_EmailReadonly"]"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

                <MudDivider Class="mb-4" />

                <!-- Canvi de contrasenya -->
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight:700">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Class="mr-1" />
                    @Loc["Profile_ChangePassword"]
                </MudText>

                <MudTextField @bind-Value="_currentPassword" Label="@Loc["Profile_CurrentPassword"]"
                              Variant="Variant.Outlined" Class="mb-3"
                              InputType="@_pwdTypeActual" Immediate="true"
                              Adornment="Adornment.End" AdornmentIcon="@_pwdIconActual"
                              OnAdornmentClick="() => _showActual = !_showActual"
                              HelperText="@Loc["Profile_CurrentPwdHint"]" />
                <MudTextField @bind-Value="_newPassword" Label="@Loc["Profile_NewPassword"]"
                              Variant="Variant.Outlined" Class="mb-3"
                              InputType="@_pwdTypeNova" Immediate="true"
                              Adornment="Adornment.End" AdornmentIcon="@_pwdIconNova"
                              OnAdornmentClick="() => _showNova = !_showNova"
                              HelperText="@Loc["Profile_PwdHint"]" />
                <MudTextField @bind-Value="_confirmPassword" Label="@Loc["Profile_ConfirmPassword"]"
                              Variant="Variant.Outlined" Class="mb-4"
                              InputType="InputType.Password" Immediate="true" />

                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                }
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="SaveAsync" Disabled="_saving"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @Loc["EditProf_Save"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    private string _nom             = "";
    private string _cognoms         = "";
    private string _email           = "";
    private string _currentPassword = "";
    private string _newPassword     = "";
    private string _confirmPassword = "";
    private bool   _loading         = true;
    private bool   _saving          = false;
    private string? _error;

    private bool _showActual = false;
    private bool _showNova   = false;
    private InputType _pwdTypeActual => _showActual ? InputType.Text : InputType.Password;
    private InputType _pwdTypeNova   => _showNova   ? InputType.Text : InputType.Password;
    private string _pwdIconActual => _showActual ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string _pwdIconNova   => _showNova   ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        Api.SetToken(UserState.Token!);
        var prof = await Api.GetOwnProfileAsync();
        if (prof is null) { Nav.NavigateTo("/professor/dashboard"); return; }
        _nom     = prof.Nom;
        _cognoms = prof.Cognoms;
        _email   = prof.Email;
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _error = null;

        // Validació de contrasenya si s'omple
        if (!string.IsNullOrWhiteSpace(_newPassword) || !string.IsNullOrWhiteSpace(_currentPassword))
        {
            if (string.IsNullOrWhiteSpace(_currentPassword))
            { _error = Loc["Profile_NeedCurrentPwd"].Value; return; }
            if (string.IsNullOrWhiteSpace(_newPassword))
            { _error = Loc["Profile_EmptyNewPwd"].Value; return; }
            if (_newPassword.Length < 8)
            { _error = Loc["Profile_PwdTooShort"].Value; return; }
            if (_newPassword != _confirmPassword)
            { _error = Loc["Profile_PwdMismatch"].Value; return; }
        }

        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms))
        { _error = Loc["Profile_NameRequired"].Value; return; }

        _saving = true;
        Api.SetToken(UserState.Token!);
        var req = new UpdateOwnProfileRequest(
            _nom.Trim(), _cognoms.Trim(),
            string.IsNullOrWhiteSpace(_currentPassword) ? null : _currentPassword,
            string.IsNullOrWhiteSpace(_newPassword)     ? null : _newPassword);

        var result = await Api.UpdateOwnProfileAsync(req);
        _saving = false;

        if (result is null)
        {
            _error = Loc["Profile_SaveError"].Value;
        }
        else
        {
            // Actualitza la sessió amb el nou nom (manté la FotoUrl actual)
            var session = new LoginResponse(UserState.Token!, result.NomComplet,
                UserState.Role!, result.Id, UserState.FotoUrl);
            try { await LocalStorage.SetAsync("autoco_session", session); } catch { }
            UserState.SetLogin(session);

            _nom     = result.Nom;
            _cognoms = result.Cognoms;
            _currentPassword = "";
            _newPassword     = "";
            _confirmPassword = "";
            Snackbar.Add(Loc["Profile_Updated"].Value, Severity.Success);
        }
    }

    private async Task UploadFotoAsync(IBrowserFile file)
    {
        if (UserState.UserId is null) return;
        Api.SetToken(UserState.Token!);
        var url = await Api.UploadProfessorFotoAsync(UserState.UserId.Value, file);
        if (url is not null)
        {
            UserState.UpdateFotoUrl(url);
            var session = new LoginResponse(UserState.Token!, UserState.NomComplet!,
                UserState.Role!, UserState.UserId.Value, url);
            try { await LocalStorage.SetAsync("autoco_session", session); } catch { }
            Snackbar.Add(Loc["Profile_FotoUpdated"].Value, Severity.Success);
        }
        else Snackbar.Add(Loc["Profile_FotoError"].Value, Severity.Error);
    }

    private async Task DeleteFotoAsync()
    {
        if (UserState.UserId is null) return;
        Api.SetToken(UserState.Token!);
        var ok = await Api.DeleteProfessorFotoAsync(UserState.UserId.Value);
        if (ok)
        {
            UserState.UpdateFotoUrl(null);
            var session = new LoginResponse(UserState.Token!, UserState.NomComplet!,
                UserState.Role!, UserState.UserId.Value, null);
            try { await LocalStorage.SetAsync("autoco_session", session); } catch { }
            Snackbar.Add(Loc["Profile_FotoDeleted"].Value, Severity.Success);
        }
    }
}
