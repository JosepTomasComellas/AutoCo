@page "/professor/alumnes/{ClassId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Alumnes – AutoCo</PageTitle>
@if (!UserState.IsProfessor) { Nav.NavigateTo("/"); return; }

@if (_classe is null && !_loading)
{
    <MudAlert Severity="Severity.Error">Classe no trobada.</MudAlert>
    <MudButton Href="/professor/classes" Class="mt-2">← Tornar</MudButton>
    return;
}

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/classes"
               Variant="Variant.Text" Color="Color.Default">Classes</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Class="mr-1" />
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Style="font-weight:700">@_classe?.Name</MudText>
        @if (_classe?.AcademicYear is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@_classe.AcademicYear</MudText>
        }
    </MudStack>
    <MudSpacer />
    @if (UserState.IsAdmin)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Email"
                   OnClick="SendAllAsync">
            Enviar contrasenya a tots
        </MudButton>
    }
    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Download"
               OnClick="ExportCsvAsync">
        Exportar llista
    </MudButton>
</MudStack>

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" /> }

<MudGrid>
    @if (UserState.IsAdmin)
    {
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Class="mb-4">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="@(_editStudentId == 0 ? Color.Primary : Color.Warning)"
                                   Variant="Variant.Filled" Size="Size.Small">
                            <MudIcon Icon="@(_editStudentId == 0 ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@(_editStudentId == 0 ? "Nou alumne" : "Editar alumne")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_nom" Label="Nom" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField @bind-Value="_cognoms" Label="Cognoms" Variant="Variant.Outlined" Immediate="true" />
                        </MudItem>
                    </MudGrid>
                    <MudNumericField T="int" @bind-Value="_numLlista" Label="Núm. llista"
                                     Variant="Variant.Outlined" Min="1" Max="99" Class="mt-3" />
                    <MudTextField @bind-Value="_correu" Label="Correu electrònic"
                                  Variant="Variant.Outlined" InputType="InputType.Email"
                                  Class="mt-3" Immediate="true" />
                </MudCardContent>
                <MudCardActions Class="px-4 pb-4 gap-2">
                    @if (_editStudentId == 0)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   OnClick="AddAsync" Disabled="_saving"
                                   StartIcon="@Icons.Material.Filled.PersonAdd">
                            Afegir alumne
                        </MudButton>
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                   OnClick="SaveEditAsync" Disabled="_saving"
                                   StartIcon="@Icons.Material.Filled.Save">
                            Desar canvis
                        </MudButton>
                        <MudButton Variant="Variant.Text" OnClick="CancelEdit">Cancel·lar</MudButton>
                    }
                </MudCardActions>
            </MudCard>

            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent><MudText Typo="Typo.h6">Importar llista d'alumnes</MudText></CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                        <strong>CSV:</strong> <code>NumLlista;Nom;Cognoms;Correu</code>
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        <strong>XLS/XLSX:</strong> llista directa de la web de l'escola
                    </MudText>
                    <MudFileUpload T="IBrowserFile" Accept=".csv,.txt,.xls,.xlsx" FilesChanged="OnImportFileSelected">
                        <ActivatorContent>
                            <MudButton Variant="Variant.Outlined" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.AttachFile">
                                @(_importFile is null ? "Seleccionar fitxer" : _importFile.Name)
                            </MudButton>
                        </ActivatorContent>
                    </MudFileUpload>
                </MudCardContent>
                <MudCardActions Class="px-4 pb-4 gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               OnClick="ImportAsync" Disabled="_importFile is null || _saving"
                               StartIcon="@Icons.Material.Filled.Upload">
                        Importar
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small"
                               Href="/templates/alumnes-plantilla.csv" download="alumnes-plantilla.csv"
                               StartIcon="@Icons.Material.Filled.Download">
                        Plantilla CSV
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    }

    <MudItem xs="12" md="@(UserState.IsAdmin ? 8 : 12)">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.h6" Style="font-weight:600">Alumnes (@_students.Count)</MudText>
            <MudSpacer />
            @if (UserState.IsAdmin && _students.Any())
            {
                <MudCheckBox T="bool" Value="_allSelected" ValueChanged="ToggleSelectAll"
                             Color="Color.Primary" Size="Size.Small"
                             Label="@(_selected.Count == 0 ? "Seleccionar tots" : $"{_selected.Count} seleccionats")"
                             Style="margin:0" />
            }
        </MudStack>

        @* Barra d'accions massives *@
        @if (UserState.IsAdmin && _selected.Any())
        {
            <MudPaper Elevation="2" Class="pa-2 mb-2 d-flex align-center flex-wrap gap-2"
                      Style="background:var(--mud-palette-primary);border-radius:8px">
                <MudText Typo="Typo.body2" Style="color:white;font-weight:600;flex-shrink:0">
                    @_selected.Count alumne@(_selected.Count != 1 ? "s" : "") seleccionat@(_selected.Count != 1 ? "s" : "")
                </MudText>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.2);color:white"
                           StartIcon="@Icons.Material.Filled.Email"
                           OnClick="BulkSendPasswordsAsync">
                    Enviar contrasenya
                </MudButton>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.2);color:white"
                           StartIcon="@Icons.Material.Filled.Key"
                           OnClick="BulkResetPasswordsAsync">
                    Nova contrasenya
                </MudButton>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.2);color:white"
                           StartIcon="@Icons.Material.Filled.DriveFileMove"
                           OnClick="BulkMoveAsync">
                    Moure a...
                </MudButton>
                <MudButton Variant="Variant.Filled" Size="Size.Small" Disabled="_saving"
                           Style="background:rgba(255,255,255,.15);color:white;border:1px solid rgba(255,255,255,.5)"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="BulkDeleteAsync">
                    Eliminar
                </MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Style="color:white" title="Desseleccionar tots"
                               OnClick="() => _selected.Clear()" />
            </MudPaper>
        }

        <MudDataGrid T="StudentDto" Items="_students" Dense="true" Hover="true"
                     SortMode="SortMode.Single" RowsPerPage="25">
            <PagerContent>
                @if (_students.Count > 25)
                {
                    <MudDataGridPager T="StudentDto" PageSizeOptions="new[]{25,50,100}" />
                }
            </PagerContent>
            <Columns>
                @if (UserState.IsAdmin)
                {
                    <TemplateColumn T="StudentDto" CellStyle="width:32px;padding:0 4px">
                        <HeaderTemplate><span /></HeaderTemplate>
                        <CellTemplate>
                            <MudCheckBox T="bool"
                                         Value="_selected.Contains(context.Item.Id)"
                                         ValueChanged="v => ToggleSelect(context.Item.Id, v)"
                                         Color="Color.Primary" Size="Size.Small" />
                        </CellTemplate>
                    </TemplateColumn>
                }
                <TemplateColumn Title="#">
                    <HeaderTemplate>
                        <MudTooltip Text="Núm. de llista" Placement="Placement.Top">
                            <span style="cursor:help">#</span>
                        </MudTooltip>
                    </HeaderTemplate>
                    <CellTemplate>@context.Item.NumLlista</CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Alumne">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Style="@GetAvatarStyle(context.Item)" Size="Size.Small">
                                @GetInitials(context.Item)
                            </MudAvatar>
                            <span>@context.Item.Cognoms, @context.Item.Nom</span>
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="s => s.Email" Title="Correu" />
                @if (UserState.IsAdmin)
                {
                    <TemplateColumn Title="" CellStyle="white-space:nowrap">
                        <CellTemplate>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary" title="Editar"
                                           OnClick="() => StartEdit(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Email" Size="Size.Small"
                                           Color="Color.Secondary" title="Enviar contrasenya"
                                           OnClick="() => SendPasswordAsync(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Key" Size="Size.Small"
                                           Color="Color.Warning" title="Generar nova contrasenya"
                                           OnClick="() => ResetPasswordAsync(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.DriveFileMove" Size="Size.Small"
                                           Color="Color.Info" title="Moure a una altra classe"
                                           OnClick="() => MoveOneAsync(context.Item)" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" title="Eliminar"
                                           OnClick="() => DeleteAsync(context.Item)" />
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
        </MudDataGrid>
    </MudItem>
</MudGrid>

@code {
    [Parameter] public int ClassId { get; set; }

    private ClassDto?         _classe   = null;
    private List<StudentDto>  _students = [];
    private bool _loading = true;
    private bool _saving  = false;

    private int    _numLlista    = 1;
    private string _nom          = "";
    private string _cognoms      = "";
    private string _correu       = "";
    private int    _editStudentId = 0;

    private IBrowserFile? _importFile;

    // ── Selecció massiva ──────────────────────────────────────────────────────
    private HashSet<int> _selected = [];
    private bool _allSelected => _students.Count > 0 && _selected.Count == _students.Count;

    private void ToggleSelect(int id, bool add)
    {
        if (add) _selected.Add(id);
        else     _selected.Remove(id);
    }

    private void ToggleSelectAll(bool selectAll)
    {
        if (selectAll) _selected = [.. _students.Select(s => s.Id)];
        else           _selected.Clear();
    }

    private async Task BulkSendPasswordsAsync()
    {
        if (!_selected.Any()) return;
        var ids = _selected.ToList();
        var confirm = await Dialog.ShowMessageBox("Enviar contrasenyes",
            $"S'enviarà la contrasenya per correu a {ids.Count} alumne{(ids.Count != 1 ? "s" : "")}.",
            yesText: "Enviar", cancelText: "Cancel·lar");
        if (confirm != true) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        int sent = 0, failed = 0;
        foreach (var id in ids)
        {
            var r = await Api.SendPasswordAsync(ClassId, id);
            if (r?.Sent == true) sent++; else failed++;
        }
        Snackbar.Add($"Enviades: {sent}{(failed > 0 ? $" · Fallades: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        _saving = false;
    }

    private async Task BulkResetPasswordsAsync()
    {
        if (!_selected.Any()) return;
        var ids = _selected.ToList();
        var confirm = await Dialog.ShowMessageBox("Generar noves contrasenyes",
            $"Es generarà una nova contrasenya per a {ids.Count} alumne{(ids.Count != 1 ? "s" : "")}. Les contrasenyes anteriors quedaran invàlides.",
            yesText: "Confirmar", cancelText: "Cancel·lar");
        if (confirm != true) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        int ok = 0, failed = 0;
        foreach (var id in ids)
        {
            var r = await Api.ResetPasswordAsync(ClassId, id);
            if (r is not null) ok++; else failed++;
        }
        Snackbar.Add($"Contrasenyes generades: {ok}{(failed > 0 ? $" · Errors: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        _saving = false;
    }

    private async Task BulkDeleteAsync()
    {
        if (!_selected.Any()) return;
        var ids = _selected.ToList();
        var confirm = await Dialog.ShowMessageBox("Confirmar eliminació",
            $"S'eliminaran {ids.Count} alumne{(ids.Count != 1 ? "s" : "")} i totes les seves avaluacions. Aquesta acció no es pot desfer.",
            yesText: "Eliminar", cancelText: "Cancel·lar");
        if (confirm != true) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        int ok = 0, failed = 0;
        foreach (var id in ids)
        {
            var success = await Api.DeleteStudentAsync(ClassId, id);
            if (success) ok++; else failed++;
        }
        Snackbar.Add($"Eliminats: {ok}{(failed > 0 ? $" · Errors: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        await LoadAsync();
        _saving = false;
    }

    // ── Moure alumnes ────────────────────────────────────────────────────────

    private async Task MoveOneAsync(StudentDto s)
    {
        var targetClassId = await PickTargetClassAsync();
        if (targetClassId is null) return;

        _saving = true;
        Api.SetToken(UserState.Token!);
        var moved = await Api.MoveStudentAsync(ClassId, s.Id, targetClassId.Value);
        if (moved is not null)
        {
            Snackbar.Add($"«{s.NomComplet}» mogut/da correctament.", Severity.Success);
            await LoadAsync();
        }
        else Snackbar.Add("Error en moure l'alumne.", Severity.Error);
        _saving = false;
    }

    private async Task BulkMoveAsync()
    {
        if (!_selected.Any()) return;
        var targetClassId = await PickTargetClassAsync();
        if (targetClassId is null) return;

        var ids = _selected.ToList();
        _saving = true;
        Api.SetToken(UserState.Token!);
        int ok = 0, failed = 0;
        foreach (var id in ids)
        {
            var moved = await Api.MoveStudentAsync(ClassId, id, targetClassId.Value);
            if (moved is not null) ok++; else failed++;
        }
        Snackbar.Add($"Moguts: {ok}{(failed > 0 ? $" · Errors: {failed}" : "")}",
            failed > 0 ? Severity.Warning : Severity.Success);
        _selected.Clear();
        await LoadAsync();
        _saving = false;
    }

    private async Task<int?> PickTargetClassAsync()
    {
        Api.SetToken(UserState.Token!);
        var classes = await Api.GetClassesAsync() ?? [];
        var others  = classes.Where(c => c.Id != ClassId).ToList();
        if (!others.Any()) { Snackbar.Add("No hi ha altres classes disponibles.", Severity.Info); return null; }

        var opts   = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var param  = new DialogParameters<MoureAlumneDialog> { { d => d.Classes, others } };
        var dialog = await Dialog.ShowAsync<MoureAlumneDialog>("Moure a classe", param, opts);
        var result = await dialog.Result;
        if (result is null || result.Canceled) return null;
        return (int)result.Data!;
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsProfessor) return;
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        Api.SetToken(UserState.Token!);
        _classe   = await Api.GetClassAsync(ClassId);
        _students = await Api.GetStudentsAsync(ClassId) ?? [];
    }

    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms) ||
            string.IsNullOrWhiteSpace(_correu))
        {
            Snackbar.Add("Nom, Cognoms i Correu són obligatoris.", Severity.Warning); return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var s = await Api.AddStudentAsync(ClassId,
            new CreateStudentRequest(_nom.Trim(), _cognoms.Trim(), _numLlista, _correu.Trim()));
        if (s is not null)
        {
            _students.Add(s);
            _students = [.. _students.OrderBy(x => x.NumLlista)];
            _nom = ""; _cognoms = ""; _correu = ""; _numLlista++;
            Snackbar.Add($"Alumne «{s.NomComplet}» afegit.", Severity.Success);
        }
        else Snackbar.Add("Error en afegir l'alumne. Comprova que el correu no estigui duplicat.", Severity.Error);
        _saving = false;
    }

    private void StartEdit(StudentDto s)
    {
        _editStudentId = s.Id;
        _nom           = s.Nom;
        _cognoms       = s.Cognoms;
        _numLlista     = s.NumLlista;
        _correu        = s.Email;
    }

    private void CancelEdit()
    {
        _editStudentId = 0;
        _nom = ""; _cognoms = ""; _correu = ""; _numLlista = 1;
    }

    private async Task SaveEditAsync()
    {
        if (string.IsNullOrWhiteSpace(_nom) || string.IsNullOrWhiteSpace(_cognoms) ||
            string.IsNullOrWhiteSpace(_correu))
        {
            Snackbar.Add("Nom, Cognoms i Correu són obligatoris.", Severity.Warning); return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var updated = await Api.UpdateStudentAsync(ClassId, _editStudentId,
            new UpdateStudentRequest(_nom.Trim(), _cognoms.Trim(), _numLlista, _correu.Trim()));
        if (updated is not null)
        {
            var idx = _students.FindIndex(x => x.Id == _editStudentId);
            if (idx >= 0) _students[idx] = updated;
            _students = [.. _students.OrderBy(x => x.NumLlista)];
            CancelEdit();
            Snackbar.Add($"Alumne «{updated.NomComplet}» actualitzat.", Severity.Success);
        }
        else Snackbar.Add("Error en actualitzar. Comprova que el correu no estigui duplicat.", Severity.Error);
        _saving = false;
    }

    private void OnImportFileSelected(IBrowserFile file) => _importFile = file;

    private async Task ImportAsync()
    {
        if (_importFile is null) return;
        _saving = true;

        var ext = System.IO.Path.GetExtension(_importFile.Name).ToLowerInvariant();
        List<CreateStudentRequest> students;
        List<string> errors;

        if (ext is ".xls" or ".xlsx")
            (students, errors) = await ParseXlsAsync();
        else
            (students, errors) = await ParseCsvAsync();

        if (students.Count == 0)
        {
            Snackbar.Add(errors.Any()
                ? "Errors al fitxer: " + string.Join("; ", errors.Take(3))
                : "Fitxer buit o sense dades vàlides.", Severity.Warning);
            _saving = false;
            return;
        }

        Api.SetToken(UserState.Token!);
        var result = await Api.BulkAddStudentsAsync(ClassId, new BulkCreateStudentsRequest(students));
        if (result is not null)
        {
            Snackbar.Add($"Importació: {result.Created} creats, {result.Skipped} omesos.", Severity.Success);
            if (result.Errors.Any())
                Snackbar.Add(string.Join(" | ", result.Errors.Take(3)), Severity.Warning);
        }
        _importFile = null;
        await LoadAsync();
        _saving = false;
    }

    private async Task<(List<CreateStudentRequest>, List<string>)> ParseCsvAsync()
    {
        var students = new List<CreateStudentRequest>();
        var errors   = new List<string>();

        using var stream = _importFile!.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var reader = new System.IO.StreamReader(stream);
        var content = await reader.ReadToEndAsync();
        var lines   = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);

        int lineNum = 0;
        foreach (var rawLine in lines)
        {
            lineNum++;
            var line = rawLine.TrimEnd('\r');
            if (string.IsNullOrWhiteSpace(line)) continue;
            var cols = line.Split(';');
            if (lineNum == 1 && !int.TryParse(cols[0].Trim(), out _)) continue; // capçalera opcional
            if (cols.Length < 4) { errors.Add($"Línia {lineNum}: calen 4 columnes (NumLlista;Nom;Cognoms;Correu)."); continue; }
            if (!int.TryParse(cols[0].Trim(), out var num)) { errors.Add($"Línia {lineNum}: NumLlista invàlid."); continue; }
            var nom    = cols[1].Trim();
            var cog    = cols[2].Trim();
            var correu = cols[3].Trim();
            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cog) || string.IsNullOrEmpty(correu))
            { errors.Add($"Línia {lineNum}: camps buits."); continue; }
            students.Add(new CreateStudentRequest(nom, cog, num, correu));
        }

        return (students, errors);
    }

    private async Task<(List<CreateStudentRequest>, List<string>)> ParseXlsAsync()
    {
        // Llegim tot l'stream en memòria per poder detectar el format
        using var inputStream = _importFile!.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        var ms = new System.IO.MemoryStream();
        await inputStream.CopyToAsync(ms);
        ms.Position = 0;

        // Molts sistemes escolars web exporten "XLS" que en realitat és una taula HTML.
        // Ho detectem llegint el primer byte: si és '<', és HTML.
        if (ms.Length > 0 && ms.ReadByte() == (byte)'<')
        {
            ms.Position = 0;
            return ParseHtmlTable(ms);
        }

        // Excel binari real (BIFF8 .xls o OpenXML .xlsx)
        ms.Position = 0;
        return ParseBinaryExcel(ms);
    }

    /// <summary>
    /// Parseja la taula HTML exportada per la web de l'escola.
    /// Format: &lt;tr&gt; amb 10 &lt;td&gt;: Num|Cognoms|Nom|DNI|Naix|Baixa|Repetidor|Tel1|Tel2|Email
    /// Encoding: ISO-8859-1 (Windows-1252) — típic de sistemes web antics.
    /// </summary>
    private static (List<CreateStudentRequest>, List<string>) ParseHtmlTable(System.IO.MemoryStream ms)
    {
        var students = new List<CreateStudentRequest>();
        var errors   = new List<string>();

        // ISO-8859-1 per preservar caràcters accentuats (é, à, ç, ...)
        var encoding = System.Text.Encoding.GetEncoding("iso-8859-1");
        var content  = encoding.GetString(ms.ToArray());

        // Extreure files <tr>...</tr>
        var rows = System.Text.RegularExpressions.Regex.Matches(
            content, @"<tr[^>]*>(.*?)</tr>",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase |
            System.Text.RegularExpressions.RegexOptions.Singleline);

        bool headerSkipped = false;
        int  rowNum        = 0;

        foreach (System.Text.RegularExpressions.Match row in rows)
        {
            rowNum++;
            var rowHtml = row.Groups[1].Value;

            // Primera fila amb <b> = capçalera → saltar
            if (!headerSkipped)
            {
                if (rowHtml.Contains("<b>", StringComparison.OrdinalIgnoreCase))
                    { headerSkipped = true; continue; }
            }

            // Extreure cel·les i eliminar etiquetes HTML interiors
            var cells = System.Text.RegularExpressions.Regex.Matches(
                rowHtml, @"<td[^>]*>(.*?)</td>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase |
                System.Text.RegularExpressions.RegexOptions.Singleline)
                .Select(m => System.Text.RegularExpressions.Regex
                    .Replace(m.Groups[1].Value, "<[^>]+>", "").Trim())
                .ToList();

            if (cells.Count < 10) continue; // fila incompleta o buida

            var numRaw  = cells[0];
            // Els cognoms tenen espais múltiples de padding → normalitzar
            var cognoms = System.Text.RegularExpressions.Regex.Replace(cells[1].Trim(), @"\s+", " ");
            var nom     = cells[2].Trim();
            var baixa   = cells[5].Trim();
            var email   = cells[9].Trim();

            if (!string.IsNullOrEmpty(baixa)) continue; // alumne de baixa
            if (string.IsNullOrEmpty(numRaw) && string.IsNullOrEmpty(nom)) continue; // fila buida

            if (!int.TryParse(numRaw, out var numLlista))
            { errors.Add($"Fila {rowNum}: número de llista invàlid ('{numRaw}')."); continue; }

            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cognoms) || string.IsNullOrEmpty(email))
            { errors.Add($"Fila {rowNum}: camps obligatoris buits."); continue; }

            students.Add(new CreateStudentRequest(nom, cognoms, numLlista, email));
        }

        return (students, errors);
    }

    /// <summary>Parseja Excel binari real (.xls BIFF8 o .xlsx OpenXML) via ExcelDataReader.</summary>
    private static (List<CreateStudentRequest>, List<string>) ParseBinaryExcel(System.IO.MemoryStream ms)
    {
        var students = new List<CreateStudentRequest>();
        var errors   = new List<string>();

        using var excelReader = ExcelDataReader.ExcelReaderFactory.CreateReader(ms);
        var ds = excelReader.AsDataSet(new ExcelDataReader.ExcelDataSetConfiguration
        {
            ConfigureDataTable = _ => new ExcelDataReader.ExcelDataTableConfiguration { UseHeaderRow = false }
        });

        if (ds.Tables.Count == 0) return (students, errors);
        var sheet = ds.Tables[0];

        // Fila 0: nom classe · Fila 1: buida · Fila 2: capçaleres → dades des de fila 3
        for (int r = 3; r < sheet.Rows.Count; r++)
        {
            var row     = sheet.Rows[r];
            var numRaw  = row[0]?.ToString()?.Trim() ?? "";
            var cognoms = row[1]?.ToString()?.Trim() ?? "";
            var nom     = row[2]?.ToString()?.Trim() ?? "";
            var baixa   = row[5]?.ToString()?.Trim() ?? "";
            var email   = row[9]?.ToString()?.Trim() ?? "";

            if (!string.IsNullOrEmpty(baixa)) continue;
            if (string.IsNullOrEmpty(numRaw) && string.IsNullOrEmpty(nom)) continue;

            int numLlista;
            if (!int.TryParse(numRaw, out numLlista))
            {
                if (double.TryParse(numRaw, System.Globalization.NumberStyles.Any,
                    System.Globalization.CultureInfo.InvariantCulture, out var numD))
                    numLlista = (int)numD;
                else { errors.Add($"Fila {r + 1}: número de llista invàlid ('{numRaw}')."); continue; }
            }

            if (string.IsNullOrEmpty(nom) || string.IsNullOrEmpty(cognoms) || string.IsNullOrEmpty(email))
            { errors.Add($"Fila {r + 1}: camps obligatoris buits."); continue; }

            students.Add(new CreateStudentRequest(nom, cognoms, numLlista, email));
        }

        return (students, errors);
    }

    // ── Avatars ──────────────────────────────────────────────────────────────

    private static string GetInitials(StudentDto s)
    {
        var cog = s.Cognoms?.TrimStart().FirstOrDefault();
        var nom = s.Nom?.TrimStart().FirstOrDefault();
        return $"{cog}{nom}".ToUpper();
    }

    private static readonly string[] _avatarColors =
        ["#CC0000", "#1e293b", "#0891b2", "#059669", "#7c3aed", "#d97706", "#db2777"];

    private static string GetAvatarStyle(StudentDto s)
    {
        var color = _avatarColors[s.NumLlista % _avatarColors.Length];
        return $"background:{color};color:white;font-size:0.68rem;width:28px;height:28px;min-width:28px";
    }

    private async Task SendPasswordAsync(StudentDto s)
    {
        Api.SetToken(UserState.Token!);
        var result = await Api.SendPasswordAsync(ClassId, s.Id);
        if (result?.Sent == true) Snackbar.Add("Contrasenya enviada.", Severity.Success);
        else Snackbar.Add($"No s'ha pogut enviar: {result?.Reason}", Severity.Error);
    }

    private async Task SendAllAsync()
    {
        var confirm = await Dialog.ShowMessageBox("Confirmar",
            "Enviar nova contrasenya a tots els alumnes?",
            yesText: "Enviar", cancelText: "Cancel·lar");
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        var result = await Api.SendAllPasswordsAsync(ClassId);
        if (result is not null)
            Snackbar.Add($"Enviades: {result.Sent} · Omeses: {result.Skipped}", Severity.Success);
    }

    private async Task ResetPasswordAsync(StudentDto s)
    {
        var confirm = await Dialog.ShowMessageBox("Confirmar",
            $"Generar nova contrasenya per a «{s.NomComplet}»?",
            yesText: "Confirmar", cancelText: "Cancel·lar");
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        var result = await Api.ResetPasswordAsync(ClassId, s.Id);
        if (result is not null)
            Snackbar.Add($"Nova contrasenya generada per a {s.NomComplet}. Comunica-la per un canal segur.", Severity.Success);
    }

    private async Task DeleteAsync(StudentDto s)
    {
        var confirm = await Dialog.ShowMessageBox("Confirmar eliminació",
            $"Eliminar «{s.NomComplet}»?",
            yesText: "Eliminar", cancelText: "Cancel·lar");
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        await Api.DeleteStudentAsync(ClassId, s.Id);
        _students.RemoveAll(x => x.Id == s.Id);
        Snackbar.Add("Alumne eliminat.", Severity.Info);
    }

    private async Task ExportCsvAsync()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("NumLlista;Nom;Cognoms;Correu");
        foreach (var s in _students.OrderBy(x => x.NumLlista))
            sb.AppendLine($"{s.NumLlista};{s.Nom};{s.Cognoms};{s.Email}");
        var fileName = $"alumnes-{_classe?.Name ?? ClassId.ToString()}.csv".Replace(" ", "_");
        await JS.InvokeVoidAsync("eval", $@"
            (function(){{
                var blob = new Blob([{System.Text.Json.JsonSerializer.Serialize(sb.ToString())}],
                    {{type:'text/csv;charset=utf-8;'}});
                var url = URL.createObjectURL(blob);
                var a = document.createElement('a');
                a.href = url; a.download = {System.Text.Json.JsonSerializer.Serialize(fileName)};
                document.body.appendChild(a); a.click();
                document.body.removeChild(a); URL.revokeObjectURL(url);
            }})()");
    }
