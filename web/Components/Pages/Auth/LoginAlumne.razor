@page "/auth/login-alumne"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav

<PageTitle>Accés Alumne – AutoCo</PageTitle>

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center">
    <MudContainer MaxWidth="MaxWidth.ExtraSmall">
        <MudPaper Elevation="4" Style="overflow:hidden;border-radius:12px">

            <div style="background:#1e293b;padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem">
                <MudIcon Icon="@Icons.Material.Filled.Person"
                         Style="color:rgba(255,255,255,.9);font-size:2rem;flex-shrink:0" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="color:white;font-weight:700;line-height:1.2">
                        Accés Alumne
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.55)">
                        AutoCo · Avaluació entre iguals
                    </MudText>
                </MudStack>
            </div>

            <div style="padding:1.75rem 2rem">
                @if (_error is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                }

                <MudSelect T="int" @bind-Value="_classId" Label="Classe" Variant="Variant.Outlined"
                           Class="mb-3" Disabled="_loading">
                    <MudSelectItem T="int" Value="0">-- Selecciona la classe --</MudSelectItem>
                    @foreach (var c in _classes)
                    {
                        <MudSelectItem T="int" Value="@c.Id">
                            @c.Name @(c.AcademicYear is not null ? $"({c.AcademicYear})" : "")
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudNumericField T="int" @bind-Value="_numLlista" Label="Número de llista"
                                 Variant="Variant.Outlined" Min="1" Max="99" Class="mb-3" />

                <MudTextField @bind-Value="_pin" Label="PIN"
                              Variant="Variant.Outlined" Class="mb-5"
                              Immediate="true"
                              InputType="@_pinType"
                              Adornment="Adornment.End" AdornmentIcon="@_pinIcon"
                              OnAdornmentClick="TogglePin" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Size="Size.Large"
                           OnClick="Login" Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Entrar
                </MudButton>

                <MudLink Href="/" Class="d-block text-center mt-4" Color="Color.Secondary">
                    ← Tornar
                </MudLink>
            </div>

        </MudPaper>
    </MudContainer>
</div>

@code {
    private List<ClassDto> _classes = [];
    private int    _classId   = 0;
    private int    _numLlista = 0;
    private string _pin       = "";
    private string? _error;
    private bool _loading;
    private bool _showPin;
    private InputType _pinType => _showPin ? InputType.Text : InputType.Password;
    private string   _pinIcon  => _showPin ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.IsLoggedIn)
        {
            Nav.NavigateTo(UserState.IsStudent ? "/alumne/dashboard" : "/professor/dashboard");
            return;
        }
        _classes = await Api.GetPublicClassesAsync() ?? [];
    }

    private void TogglePin() => _showPin = !_showPin;

    private async Task Login()
    {
        if (_classId <= 0 || _numLlista <= 0 || string.IsNullOrWhiteSpace(_pin))
        {
            _error = "Omple tots els camps.";
            return;
        }
        _loading = true;
        _error   = null;
        var result = await Api.LoginStudentAsync(_classId, _numLlista, _pin.Trim());
        _loading = false;
        if (result is null)
        {
            _error = "Dades incorrectes. Comprova la classe, el número i el PIN.";
            return;
        }
        UserState.SetLogin(result);
        Nav.NavigateTo("/alumne/dashboard");
    }
}
