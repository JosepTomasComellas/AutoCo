@page "/"
@inject UserStateService UserState
@inject NavigationManager Nav

<PageTitle>AutoCo Avaluació</PageTitle>

@if (UserState.IsLoggedIn)
{
    if (UserState.IsProfessor) Nav.NavigateTo("/professor/dashboard");
    else Nav.NavigateTo("/alumne/dashboard");
}

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center">
    <MudContainer MaxWidth="MaxWidth.ExtraSmall">
        <MudPaper Elevation="4" Style="overflow:hidden;border-radius:12px">

            <!-- Capçalera de la targeta, mateix color que l'AppBar -->
            <div style="background:#1e293b;padding:2rem;text-align:center">
                <MudImage Src="/images/logo2.png" Height="48"
                          Style="display:inline-block;margin-bottom:.5rem" />
                <MudText Typo="Typo.body2"
                         Style="color:rgba(255,255,255,.6);margin-top:.25rem">
                    Sistema d'Autoavaluació i Coavaluació
                </MudText>
            </div>

            <!-- Botons d'accés -->
            <div style="padding:2rem">
                <MudStack Spacing="3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true"
                               Href="/auth/login-professor"
                               StartIcon="@Icons.Material.Filled.School">
                        Accés Professor
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               Size="Size.Large" FullWidth="true"
                               Href="/auth/login-alumne"
                               StartIcon="@Icons.Material.Filled.Person">
                        Accés Alumne
                    </MudButton>
                </MudStack>
            </div>

        </MudPaper>
    </MudContainer>
</div>
