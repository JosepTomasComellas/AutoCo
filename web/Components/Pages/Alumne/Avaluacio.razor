@page "/alumne/avaluacio/{ActivityId:int}"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Avaluació – AutoCo</PageTitle>
@if (!UserState.IsStudent) { Nav.NavigateTo("/"); return; }

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_form is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">Activitat no disponible o ja tancada.</MudAlert>
    <MudButton Href="/alumne/dashboard">← Tornar al tauler</MudButton>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/alumne/dashboard" Variant="Variant.Text">
            Tornar
        </MudButton>
        <MudText Typo="Typo.h5">@_form.Activity.Name</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
            Grup: @_form.Group.Name
        </MudChip>
    </MudStack>
    @if (_form.Activity.Description is not null)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@_form.Activity.Description</MudText>
    }

    @foreach (var entry in _form.Entries)
    {
        var isSelf = entry.IsSelf;
        <MudPaper Elevation="2" Class="@($"pa-4 mb-4 {(isSelf ? "border-l-4" : "")}")"
                  Style="@(isSelf ? "border-left:4px solid var(--mud-palette-primary)" : "")">
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">@entry.StudentName</MudText>
                <MudChip T="string" Size="Size.Small"
                         Color="@(isSelf ? Color.Primary : Color.Secondary)">
                    @(isSelf ? "Autoavaluació" : "Coavaluació")
                </MudChip>
            </MudStack>

            @foreach (var criteri in _criteria)
            {
                var key     = criteri.Key;
                var current = _scores.TryGetValue((entry.StudentId, key), out var v) ? v : 0;
                <MudStack Row="false" Class="mb-3">
                    <MudText Typo="Typo.subtitle2">@criteri.Label</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        @for (int i = 1; i <= 10; i++)
                        {
                            var val = i;
                            var sid = entry.StudentId;
                            <MudIconButton Icon="@(val <= current ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                           Color="@(val <= current ? Color.Warning : Color.Default)"
                                           Size="Size.Small"
                                           OnClick="() => SetScore(sid, key, val)" />
                        }
                        <MudText Typo="Typo.body2" Style="min-width:24px">
                            @(current > 0 ? current.ToString() : "–")
                        </MudText>
                    </MudStack>
                </MudStack>
            }

            <MudTextField @bind-Value="_comments[entry.StudentId]"
                          Label="Comentari (opcional)" Variant="Variant.Outlined"
                          Lines="2" MaxLength="500" />
        </MudPaper>
    }

    <MudStack Row="true" Class="mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   OnClick="SaveAsync" Disabled="_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Guardar avaluació
        </MudButton>
    </MudStack>
}

@code {
    [Parameter] public int ActivityId { get; set; }

    private EvaluationFormDto?   _form     = null;
    private List<CriteriaDto>    _criteria = [];
    private bool _loading = true;
    private bool _saving  = false;

    // Puntuacions i comentaris: (studentId, criteriaKey) -> score
    private Dictionary<(int, string), int> _scores   = new();
    private Dictionary<int, string>        _comments = new();

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsStudent) return;
        Api.SetToken(UserState.Token!);
        _form     = await Api.GetEvaluationFormAsync(ActivityId);
        _criteria = await Api.GetCriteriaAsync() ?? [];

        if (_form is not null)
        {
            foreach (var entry in _form.Entries)
            {
                _comments[entry.StudentId] = entry.Comment ?? "";
                foreach (var c in _criteria)
                    _scores[(entry.StudentId, c.Key)] = entry.Scores.TryGetValue(c.Key, out var sv) ? sv : 0;
            }
        }
        _loading = false;
    }

    private void SetScore(int studentId, string key, int val)
    {
        var current = _scores.TryGetValue((studentId, key), out var v) ? v : 0;
        _scores[(studentId, key)] = current == val ? 0 : val;
    }

    private async Task SaveAsync()
    {
        // Validar que tots els criteris tinguin puntuació
        var missing = new List<string>();
        if (_form is not null)
        {
            foreach (var entry in _form.Entries)
                foreach (var c in _criteria)
                    if (!_scores.TryGetValue((entry.StudentId, c.Key), out var v) || v <= 0)
                        missing.Add($"{entry.StudentName} → {c.Label}");
        }
        if (missing.Any())
        {
            Snackbar.Add($"Falta puntuar: {string.Join(", ", missing.Take(3))}{(missing.Count > 3 ? "..." : "")}", Severity.Warning);
            return;
        }

        _saving = true;
        Api.SetToken(UserState.Token!);
        var request = new SaveEvaluationsRequest(
            _form!.Entries.Select(entry => new EvaluationEntryRequest(
                entry.StudentId,
                _criteria.ToDictionary(c => c.Key, c => _scores.TryGetValue((entry.StudentId, c.Key), out var sv) ? sv : 0),
                string.IsNullOrWhiteSpace(_comments[entry.StudentId]) ? null : _comments[entry.StudentId].Trim()
            )).ToList());

        var ok = await Api.SaveEvaluationsAsync(ActivityId, request);
        _saving = false;

        if (ok)
        {
            Snackbar.Add("Avaluació guardada correctament.", Severity.Success);
            Nav.NavigateTo("/alumne/dashboard");
        }
        else
            Snackbar.Add("No s'ha pogut guardar. Comprova que l'activitat estigui oberta.", Severity.Error);
    }
}
