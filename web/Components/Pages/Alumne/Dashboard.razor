@page "/alumne/dashboard"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> Loc
@inject ISnackbar Snackbar

<PageTitle>Les meves activitats – AutoCo</PageTitle>
@if (!UserState.IsStudent) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5">@Loc["Student_Welcome", UserState.NomComplet ?? ""]</MudText>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Lock"
                   title="@Loc["Student_ChangePassword"]"
                   OnClick="OpenChangePwdDialog" Size="Size.Small" />
</MudStack>

<!-- Diàleg canvi de contrasenya -->
<MudDialog @bind-IsOpen="_pwdDialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" Style="vertical-align:middle" />
            @Loc["Student_ChangePassword"]
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width:300px">
            <MudTextField @bind-Value="_pwdActual" Label="@Loc["Profile_CurrentPassword"]"
                          InputType="@_pwdTypeActual" Variant="Variant.Outlined"
                          Adornment="Adornment.End" AdornmentIcon="@_pwdIconActual"
                          OnAdornmentClick="() => _showActual = !_showActual" />
            <MudTextField @bind-Value="_pwdNova" Label="@Loc["Profile_NewPassword"]"
                          InputType="@_pwdTypeNova" Variant="Variant.Outlined"
                          HelperText="@Loc["Student_PwdMinLength"]"
                          Adornment="Adornment.End" AdornmentIcon="@_pwdIconNova"
                          OnAdornmentClick="() => _showNova = !_showNova" />
            <MudTextField @bind-Value="_pwdConfirm" Label="@Loc["Profile_ConfirmPassword"]"
                          InputType="InputType.Password" Variant="Variant.Outlined" />
            @if (_pwdError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_pwdError</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _pwdDialogOpen = false">@Loc["Action_Cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SavePasswordAsync" Disabled="_pwdSaving">
            @if (_pwdSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
            @Loc["Action_Save"]
        </MudButton>
    </DialogActions>
</MudDialog>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (!_activities.Any())
{
    <MudAlert Severity="Severity.Info">@Loc["Student_NoActivities"]</MudAlert>
}
else
{
    <!-- Filtre -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="3">
        <MudSwitch @bind-Value="_nomesPendents" Color="Color.Warning" Label="@Loc["Student_OnlyPending"]" Size="Size.Small" />
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @Loc["Student_CountOf", _filtrades.Count, _activities.Count]
        </MudText>
    </MudStack>

    @if (!_filtrades.Any())
    {
        <MudAlert Severity="Severity.Success">@Loc["Student_AllDone"]</MudAlert>
    }
    else
    {
    <MudGrid>
        @foreach (var act in _filtrades)
        {
            var pct  = act.TotalToEvaluate > 0 ? (double)act.AlreadyEvaluated / act.TotalToEvaluate * 100 : 0;
            var done = act.AlreadyEvaluated >= act.TotalToEvaluate && act.TotalToEvaluate > 0;

            <MudItem xs="12" sm="6" lg="4">
                <MudCard Elevation="2" Style="@(act.IsOpen ? "" : "opacity:.65")">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.h6">@act.Name</MudText>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(act.IsOpen ? Color.Success : Color.Default)">
                                    @(act.IsOpen ? Loc["Student_Open"].Value : Loc["Student_Closed"].Value)
                                </MudChip>
                            </MudStack>
                            <MudText Typo="Typo.caption">@Loc["Student_Group"] <strong>@act.GroupName</strong></MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    @if (act.Description is not null)
                    {
                        <MudCardContent Class="pt-0">
                            <MudText Typo="Typo.body2">@act.Description</MudText>
                        </MudCardContent>
                    }
                    <MudCardContent Class="pt-0">
                        <MudProgressLinear Value="pct" Color="@(done ? Color.Success : Color.Primary)"
                                           Rounded="true" Class="mb-1" />
                        <MudText Typo="Typo.caption">
                            @Loc["Student_EvalProgress", act.AlreadyEvaluated, act.TotalToEvaluate]
                        </MudText>
                    </MudCardContent>
                    <MudCardActions>
                        @if (act.IsOpen)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="@(done ? Color.Secondary : Color.Primary)"
                                       Href="@($"/alumne/avaluacio/{act.Id}")">
                                @(done ? Loc["Student_Review"].Value : Loc["Student_Evaluate"].Value)
                            </MudButton>
                        }
                        else
                        {
                            @if (done)
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle"
                                         Color="Color.Success" Size="Size.Small">
                                    @Loc["Student_Completed"]
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.Cancel"
                                         Color="Color.Default" Size="Size.Small">
                                    @Loc["Student_NotCompleted"]
                                </MudChip>
                            }
                        }
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
    }
}

@code {
    private List<StudentActivityDto> _activities = [];
    private bool _loading       = true;
    private bool _nomesPendents = false;

    private List<StudentActivityDto> _filtrades => _activities
        .Where(a => !_nomesPendents || (a.IsOpen && a.AlreadyEvaluated < a.TotalToEvaluate))
        .ToList();

    // Canvi de contrasenya
    private bool   _pwdDialogOpen = false;
    private string _pwdActual     = "";
    private string _pwdNova       = "";
    private string _pwdConfirm    = "";
    private bool   _pwdSaving     = false;
    private string? _pwdError;
    private bool _showActual = false;
    private bool _showNova   = false;
    private InputType _pwdTypeActual => _showActual ? InputType.Text : InputType.Password;
    private InputType _pwdTypeNova   => _showNova   ? InputType.Text : InputType.Password;
    private string _pwdIconActual => _showActual ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private string _pwdIconNova   => _showNova   ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsStudent) return;
        Api.SetToken(UserState.Token!);
        var dashboard = await Api.GetStudentDashboardAsync();
        _activities = dashboard?.Activities ?? [];
        _loading = false;
    }

    private void OpenChangePwdDialog()
    {
        _pwdActual = _pwdNova = _pwdConfirm = "";
        _pwdError  = null;
        _pwdDialogOpen = true;
    }

    private async Task SavePasswordAsync()
    {
        _pwdError = null;
        if (string.IsNullOrWhiteSpace(_pwdActual))
        { _pwdError = Loc["Profile_NeedCurrentPwd"].Value; return; }
        if (_pwdNova.Length < 6)
        { _pwdError = Loc["Student_PwdMinLength"].Value; return; }
        if (_pwdNova != _pwdConfirm)
        { _pwdError = Loc["Profile_PwdMismatch"].Value; return; }

        _pwdSaving = true;
        Api.SetToken(UserState.Token!);
        var ok = await Api.ChangeStudentPasswordAsync(_pwdActual, _pwdNova);
        _pwdSaving = false;

        if (ok)
        {
            _pwdDialogOpen = false;
            Snackbar.Add(Loc["Student_PwdChanged"].Value, Severity.Success);
        }
        else
        {
            _pwdError = Loc["Profile_NeedCurrentPwd"].Value;
        }
    }
}
