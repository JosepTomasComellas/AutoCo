@page "/admin/professors"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IStringLocalizer<SharedResources> Loc
@inject AutoCo.Web.Services.BrandingService Branding

<PageTitle>Gestió de professors – @Branding.AppName</PageTitle>
@if (!UserState.IsAdmin) { Nav.NavigateTo("/"); return; }

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">@Loc["Nav_Dashboard"]</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Color="Color.Secondary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">@Loc["Profs_Title"]</MudText>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
               StartIcon="@Icons.Material.Filled.MarkEmailRead"
               OnClick="SendAllAsync">
        @Loc["Profs_SendAll"]
    </MudButton>
</MudStack>

@if (_loading) { <MudProgressLinear Indeterminate="true" Color="Color.Secondary" Class="mb-4" /> }

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Small">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Loc["Profs_NewProf"]</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTextField @bind-Value="_email" Label="@Loc["Label_Email"]" Variant="Variant.Outlined"
                              Class="mb-3" InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email" />
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_nom" Label="@Loc["Label_Name"]" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="_cognoms" Label="@Loc["Label_Surname"]" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
                <MudCheckBox @bind-Value="_isAdmin" Label="@Loc["Profs_IsAdmin"]" Color="Color.Warning" Class="mt-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                    @Loc["Profs_AutoPassword"]
                </MudText>
            </MudCardContent>
            <MudCardActions Class="px-4 pb-4">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" FullWidth="true"
                           OnClick="CreateAsync" Disabled="_saving"
                           StartIcon="@Icons.Material.Filled.PersonAdd">
                    @Loc["Profs_CreateProf"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
            <MudText Typo="Typo.h6" Style="font-weight:600">
                @Loc["Profs_ListTitle", _professors.Count]
            </MudText>
            <MudSpacer />
            @{
                var admins = _professors.Count(p => p.IsAdmin);
            }
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                @admins admin@(admins != 1 ? "s" : "")
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                @(_professors.Count - admins) professor@((_professors.Count - admins) != 1 ? "s" : "")
            </MudChip>
        </MudStack>

        @if (!_loading && !_professors.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@Loc["Profs_NoProfs"]</MudAlert>
        }

        <MudStack Spacing="2">
            @foreach (var p in _professors)
            {
                <MudCard Elevation="1" Style="@(p.IsAdmin ? "border-left:3px solid var(--mud-palette-warning)" : "border-left:3px solid var(--mud-palette-divider)")">
                    <MudExpansionPanel>
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width:100%">
                                <MudAvatar Color="@(p.IsAdmin ? Color.Warning : Color.Default)"
                                           Variant="Variant.Filled" Size="Size.Medium"
                                           Style="font-size:.85rem;font-weight:700;flex-shrink:0">
                                    @if (p.FotoUrl is not null)
                                    {
                                        <MudImage Src="@p.FotoUrl" Width="40" Height="40" ObjectFit="ObjectFit.Cover" />
                                    }
                                    else
                                    {
                                        @(p.Nom.Length > 0 ? p.Nom[0].ToString().ToUpper() : "")@(p.Cognoms.Length > 0 ? p.Cognoms[0].ToString().ToUpper() : "")
                                    }
                                </MudAvatar>
                                <MudStack Spacing="0" Style="flex:1;min-width:0">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600">
                                            @p.Cognoms, @p.Nom
                                        </MudText>
                                        @if (p.IsAdmin)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                     Variant="Variant.Filled" Style="height:20px">Admin</MudChip>
                                        }
                                    </MudStack>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Email"
                                                     Size="Size.Small" Style="font-size:13px;vertical-align:middle" />
                                            @p.Email
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                                <MudStack Row="true" Spacing="0" @onclick:stopPropagation="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.MarkEmailRead"
                                                   Size="Size.Small" Color="Color.Secondary"
                                                   title="@Loc["Profs_SendCreds"]"
                                                   OnClick="() => SendCredentialsAsync(p)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small" Color="Color.Error"
                                                   title="@Loc["Card_Delete"]"
                                                   OnClick="() => DeleteAsync(p)" />
                                </MudStack>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudDivider />
                            <div class="pa-4">
                                <EditProfessorForm Professor="p" OnSaved="OnProfessorSaved" />

                                <MudDivider Class="my-4" />
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Class" Size="Size.Small" Class="mr-1" />
                                    @Loc["Profs_AssignedClasses"]
                                </MudText>

                                @{
                                    var assigned = _professorClasses.GetValueOrDefault(p.Id) ?? [];
                                    var assignedIds = assigned.Select(c => c.Id).ToHashSet();
                                    var available = _allClasses.Where(c => !assignedIds.Contains(c.Id)).ToList();
                                }

                                @if (!assigned.Any())
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                                        @Loc["Profs_NoAssignedClasses"]
                                    </MudText>
                                }
                                else
                                {
                                    <MudStack Spacing="1" Class="mb-3">
                                        @foreach (var cGroup in assigned.GroupBy(c => c.CicleName).OrderBy(g => g.Key))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight:600;text-transform:uppercase">
                                                @cGroup.Key
                                            </MudText>
                                            @foreach (var cls in cGroup.OrderBy(c => c.Name))
                                            {
                                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined"
                                                         Size="Size.Small"
                                                         OnClose="() => UnassignAsync(p, cls)"
                                                         CloseIcon="@Icons.Material.Filled.Close">
                                                    @cls.Name @if (cls.AcademicYear is not null) { <text> · @cls.AcademicYear</text> }
                                                </MudChip>
                                            }
                                        }
                                    </MudStack>
                                }

                                @if (available.Any())
                                {
                                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                        <MudSelect T="int" @bind-Value="@_selectedClass[p.Id]"
                                                   Label="@Loc["Profs_SelectClass"]"
                                                   Variant="Variant.Outlined" Dense="true"
                                                   Style="flex:1">
                                            @foreach (var cGroup in available.GroupBy(c => c.CicleName).OrderBy(g => g.Key))
                                            {
                                                <MudSelectItem Value="0" Disabled="true">── @cGroup.Key ──</MudSelectItem>
                                                @foreach (var cls in cGroup.OrderBy(c => c.Name))
                                                {
                                                    <MudSelectItem Value="cls.Id">@cls.Name @(cls.AcademicYear is not null ? $"· {cls.AcademicYear}" : "")</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.Add"
                                                   OnClick="() => AssignAsync(p)"
                                                   Disabled="@(_selectedClass.GetValueOrDefault(p.Id) == 0)">
                                            @Loc["Profs_AssignClass"]
                                        </MudButton>
                                    </MudStack>
                                }
                            </div>
                        </ChildContent>
                    </MudExpansionPanel>
                </MudCard>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private List<ProfessorDto> _professors = [];
    private List<ClassDto>     _allClasses = [];
    private Dictionary<int, List<ClassDto>> _professorClasses = new();
    private Dictionary<int, int>            _selectedClass    = new();
    private bool _loading = true;
    private bool _saving  = false;

    private string _email   = "";
    private string _nom     = "";
    private string _cognoms = "";
    private bool   _isAdmin = false;

    protected override async Task OnInitializedAsync()
    {
        if (!UserState.IsAdmin) return;
        Api.SetToken(UserState.Token!);
        var profsTask   = Api.GetProfessorsAsync();
        var classesTask = Api.GetClassesAsync();
        await Task.WhenAll(profsTask, classesTask);
        _professors = profsTask.Result  ?? [];
        _allClasses = classesTask.Result ?? [];
        foreach (var p in _professors) _selectedClass[p.Id] = 0;

        var assignTasks = _professors.Select(p =>
            Api.GetProfessorClassesAsync(p.Id)
               .ContinueWith(t => (p.Id, Classes: t.Result ?? [])));
        var results = await Task.WhenAll(assignTasks);
        foreach (var (profId, classes) in results)
            _professorClasses[profId] = classes;

        _loading = false;
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_nom)
            || string.IsNullOrWhiteSpace(_cognoms))
        {
            Snackbar.Add(Loc["Profs_FieldsRequired"].Value, Severity.Warning); return;
        }
        _saving = true;
        Api.SetToken(UserState.Token!);
        var p = await Api.CreateProfessorAsync(new CreateProfessorRequest(
            _email.Trim(), _nom.Trim(), _cognoms.Trim(), _isAdmin));
        if (p is not null)
        {
            _professors.Add(p);
            _professors = [.. _professors.OrderBy(x => x.Cognoms)];
            _selectedClass[p.Id]    = 0;
            _professorClasses[p.Id] = [];
            _email = ""; _nom = ""; _cognoms = ""; _isAdmin = false;
            Snackbar.Add(Loc["Profs_Created", p.NomComplet].Value, Severity.Success);
        }
        else Snackbar.Add(Loc["Profs_CreateError"].Value, Severity.Error);
        _saving = false;
    }

    private async Task SendCredentialsAsync(ProfessorDto p)
    {
        Api.SetToken(UserState.Token!);
        var result = await Api.SendProfessorCredentialsAsync(p.Id);
        if (result?.Sent == true) Snackbar.Add(Loc["Profs_CredsSent"].Value, Severity.Success);
        else Snackbar.Add(Loc["Profs_CredsError", result?.Reason ?? ""].Value, Severity.Error);
    }

    private async Task SendAllAsync()
    {
        var confirm = await Dialog.ShowMessageBoxAsync(Loc["Profs_SendAllTitle"].Value,
            Loc["Profs_SendAllMsg"].Value,
            yesText: Loc["Action_Send"].Value, cancelText: Loc["Action_Cancel"].Value);
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        var result = await Api.SendAllProfessorCredentialsAsync();
        if (result is not null)
            Snackbar.Add(Loc["Profs_SendAllResult", result.Sent, result.Skipped].Value, Severity.Success);
    }

    private async Task DeleteAsync(ProfessorDto p)
    {
        var confirm = await Dialog.ShowMessageBoxAsync(Loc["Profs_DeleteTitle"].Value,
            Loc["Profs_DeleteMsg", p.NomComplet].Value,
            yesText: Loc["Action_Delete"].Value, cancelText: Loc["Action_Cancel"].Value);
        if (confirm != true) return;
        Api.SetToken(UserState.Token!);
        await Api.DeleteProfessorAsync(p.Id);
        _professors.RemoveAll(x => x.Id == p.Id);
        Snackbar.Add(Loc["Profs_Deleted"].Value, Severity.Info);
    }

    private async Task OnProfessorSaved(ProfessorDto updated)
    {
        var idx = _professors.FindIndex(p => p.Id == updated.Id);
        if (idx >= 0) _professors[idx] = updated;
        Snackbar.Add(Loc["Profs_Updated", updated.NomComplet].Value, Severity.Success);
        await Task.CompletedTask;
    }

    private async Task AssignAsync(ProfessorDto p)
    {
        var classId = _selectedClass.GetValueOrDefault(p.Id);
        if (classId == 0) return;
        Api.SetToken(UserState.Token!);
        var ok = await Api.AssignClassAsync(p.Id, classId);
        if (ok)
        {
            var cls = _allClasses.First(c => c.Id == classId);
            _professorClasses.TryAdd(p.Id, []);
            _professorClasses[p.Id].Add(cls);
            _professorClasses[p.Id] = [.. _professorClasses[p.Id].OrderBy(c => c.CicleName).ThenBy(c => c.Name)];
            _selectedClass[p.Id] = 0;
            Snackbar.Add(Loc["Profs_ClassAssigned"].Value, Severity.Success);
        }
        else Snackbar.Add(Loc["Profs_AssignError"].Value, Severity.Error);
    }

    private async Task UnassignAsync(ProfessorDto p, ClassDto cls)
    {
        Api.SetToken(UserState.Token!);
        var ok = await Api.UnassignClassAsync(p.Id, cls.Id);
        if (ok)
        {
            _professorClasses[p.Id].RemoveAll(c => c.Id == cls.Id);
            Snackbar.Add(Loc["Profs_ClassUnassigned"].Value, Severity.Info);
        }
    }
}
