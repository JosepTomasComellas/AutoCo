@page "/admin/auditoria"
@inject ApiClient Api
@inject UserStateService UserState
@inject NavigationManager Nav

<PageTitle>Auditoria d'accions – AutoCo</PageTitle>
@if (!UserState.IsAdmin) { Nav.NavigateTo("/"); return; }

<!-- Capçalera -->
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6" Wrap="Wrap.Wrap">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/professor/dashboard"
               Variant="Variant.Text" Color="Color.Default">Tauler</MudButton>
    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
    <MudIcon Icon="@Icons.Material.Filled.ManageSearch" Color="Color.Primary" Class="mr-1" />
    <MudText Typo="Typo.h5" Style="font-weight:700">Auditoria d'accions</MudText>
    <MudSpacer />
    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary"
                   OnClick="() => LoadAsync(1)" title="Actualitzar" />
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_items is null)
{
    <MudAlert Severity="Severity.Error">Error carregant el registre d'auditoria.</MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="pa-0">
        <MudTable Items="@_items" Dense="true" Hover="true" Striped="true"
                  FixedHeader="true" Height="calc(100vh - 260px)">
            <HeaderContent>
                <MudTh>Data i hora</MudTh>
                <MudTh>Acció</MudTh>
                <MudTh>Actor</MudTh>
                <MudTh>Detalls</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.caption" Style="white-space:nowrap">
                        @context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small"
                             Color="@ActionColor(context.Action)"
                             Variant="Variant.Filled">
                        @ActionLabel(context.Action)
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@(context.ActorName ?? "—")</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @(context.Details ?? "—")
                    </MudText>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Class="pa-4" Color="Color.Secondary">
                    Sense registres d'auditoria.
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>

    @if (_totalPages > 1)
    {
        <MudStack Row="true" Justify="Justify.Center" Class="mt-4">
            <MudPagination Count="@_totalPages" Selected="@_page"
                           SelectedChanged="LoadAsync" Color="Color.Primary" />
        </MudStack>
    }

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 text-center d-block">
        @_total entrades en total
    </MudText>
}

@code {
    private List<AdminAuditLogDto>? _items;
    private bool _loading = true;
    private int  _page       = 1;
    private int  _total      = 0;
    private int  _totalPages = 1;
    private const int PageSize = 50;

    protected override async Task OnInitializedAsync() => await LoadAsync(1);

    private async Task LoadAsync(int page)
    {
        _loading = true;
        _page    = page;
        StateHasChanged();
        var result = await Api.GetAuditLogsAsync(page, PageSize);
        if (result.HasValue)
        {
            _items      = result.Value.Items;
            _total      = result.Value.Total;
            _totalPages = (int)Math.Ceiling((double)_total / PageSize);
        }
        else
        {
            _items = null;
        }
        _loading = false;
    }

    private static string ActionLabel(string action) => action switch
    {
        "professor.created"  => "Professor creat",
        "professor.deleted"  => "Professor eliminat",
        "class.deleted"      => "Classe eliminada",
        "backup.imported"    => "Backup importat",
        "backup.restored"    => "Backup restaurat",
        "log_level.changed"  => "Nivell de log canviat",
        _                    => action
    };

    private static Color ActionColor(string action) => action switch
    {
        "professor.deleted" or "class.deleted"  => Color.Error,
        "backup.imported" or "backup.restored"  => Color.Warning,
        "professor.created"                     => Color.Success,
        _                                       => Color.Default
    };
}
