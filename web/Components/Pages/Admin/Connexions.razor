@page "/admin/connexions"
@implements IAsyncDisposable
@inject IConnectionMultiplexer Redis
@inject UserStateService UserState
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject AutoCo.Web.Services.OnlinePresenceService Presence
@inject AutoCo.Web.Services.BrandingService Branding
@using System.Text.Json
@using AutoCo.Web.Services
@using StackExchange.Redis

<PageTitle>Connexions actives — @Branding.AppName</PageTitle>

@if (!UserState.IsAdminOrGestor)
{
    Nav.NavigateTo("/", forceLoad: false);
    return;
}

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4" Wrap="Wrap.Wrap">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudText Typo="Typo.h5">
            <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Class="mr-2" Style="vertical-align:middle" />
            Connexions actives
        </MudText>
        <MudTooltip Text="@($"{_totalConnections} sessions · {_totalUsers} usuaris únics")">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_totalConnections sessions</MudChip>
                @if (_totalConnections != _totalUsers)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">@_totalUsers usuaris</MudChip>
                }
            </MudStack>
        </MudTooltip>
    </MudStack>
    <MudTooltip Text="Actualitzar ara">
        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                       Color="Color.Primary" Variant="Variant.Outlined"
                       OnClick="ManualRefreshAsync"
                       Disabled="_refreshing" />
    </MudTooltip>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    @if (_professors.Any())
    {
        <MudText Typo="Typo.subtitle1" Class="mb-2 mt-2">
            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" Class="mr-1" />
            Professors (@_professors.Count)
        </MudText>
        <MudGrid Spacing="2" Class="mb-4">
            @foreach (var u in _professors)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    @UserCard(u)
                </MudItem>
            }
        </MudGrid>
    }

    @if (_studentsByClass.Any())
    {
        <MudText Typo="Typo.subtitle1" Class="mb-2 mt-4">
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mr-1" />
            Alumnes (@_students.Count)
        </MudText>
        @foreach (var group in _studentsByClass.OrderBy(g => g.Key))
        {
            <MudText Typo="Typo.subtitle2" Class="mb-1 mt-3" Color="Color.Secondary">
                @group.Key (@group.Value.Count)
            </MudText>
            <MudGrid Spacing="2" Class="mb-2">
                @foreach (var u in group.Value)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        @UserCard(u)
                    </MudItem>
                }
            </MudGrid>
        }
    }

    @if (_totalConnections == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">No hi ha cap usuari connectat en aquest moment.</MudAlert>
    }
}

<MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-4 d-block">
    Actualitzat fa @_secondsSinceRefresh s · S'actualitza automàticament cada 10 s
</MudText>

@code {
    private List<OnlineUserSnapshot> _professors     = [];
    private List<OnlineUserSnapshot> _students       = [];
    private Dictionary<string, List<OnlineUserSnapshot>> _studentsByClass = [];
    private HashSet<int> _multiSessionIds = [];
    private int    _totalConnections    = 0;
    private int    _totalUsers          = 0;
    private bool   _loading             = true;
    private bool   _refreshing          = false;
    private int    _secondsSinceRefresh = 0;
    private Timer? _timer;
    private string _ownCircuitId        => Presence.CircuitId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(showSpinner: true);
        _timer = new Timer(async state =>
        {
            _secondsSinceRefresh++;
            if (_secondsSinceRefresh >= 10)
            {
                _secondsSinceRefresh = 0;
                await LoadAsync(showSpinner: false);
            }
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private async Task ManualRefreshAsync()
    {
        _refreshing = true;
        _secondsSinceRefresh = 0;
        await LoadAsync(showSpinner: false);
        _refreshing = false;
        StateHasChanged();
    }

    private async Task LoadAsync(bool showSpinner)
    {
        if (showSpinner) _loading = true;
        try
        {
            var server = Redis.GetServer(Redis.GetEndPoints().First());
            var keys   = server.Keys(pattern: "autoco:online:*").ToList();
            var db     = Redis.GetDatabase();

            var all = new List<OnlineUserSnapshot>();
            foreach (var key in keys)
            {
                var val = await db.StringGetAsync(key);
                if (val.IsNull) continue;
                try
                {
                    var snap = JsonSerializer.Deserialize<OnlineUserSnapshot>(val.ToString());
                    if (snap is not null) all.Add(snap);
                }
                catch { /* JSON invàlid, ignora */ }
            }

            _professors     = all.Where(u => u.Role != "Student")
                                 .OrderBy(u => RoleOrder(u.Role))
                                 .ThenBy(u => u.DisplayName)
                                 .ToList();
            _students       = all.Where(u => u.Role == "Student")
                                 .OrderBy(u => u.ClassName)
                                 .ThenBy(u => u.DisplayName)
                                 .ToList();
            _studentsByClass = _students
                .GroupBy(u => u.ClassName ?? "Sense classe")
                .ToDictionary(g => g.Key, g => g.ToList());
            _multiSessionIds = all.GroupBy(u => u.Id)
                                  .Where(g => g.Count() > 1)
                                  .Select(g => g.Key)
                                  .ToHashSet();
            _totalConnections = all.Count;
            _totalUsers       = all.Select(u => u.Id).Distinct().Count();
        }
        finally
        {
            _loading = false;
        }
    }

    private RenderFragment UserCard(OnlineUserSnapshot u) => __builder =>
    {
        var isSelf = u.CircuitId is not null && u.CircuitId == _ownCircuitId;
        <MudCard Elevation="1">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudAvatar Size="Size.Medium">
                        @if (u.PhotoUrl is not null)
                        {
                            <MudImage Src="@u.PhotoUrl" Style="width:100%;height:100%;object-fit:cover" />
                        }
                        else
                        {
                            @Initials(u.DisplayName)
                        }
                    </MudAvatar>
                    <MudStack Spacing="0" Style="min-width:0;flex:1">
                        <MudText Typo="Typo.body2"
                                 Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @u.DisplayName
                        </MudText>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            <MudChip T="string" Size="Size.Small" Color="@RoleColor(u.Role)">
                                @RoleLabel(u.Role)
                            </MudChip>
                            <MudText Typo="Typo.caption" Color="Color.Tertiary">
                                @RelativeTime(u.ConnectedAt)
                            </MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                            @if (u.IpAddress is not null)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Tertiary"
                                         Style="font-family:monospace;font-size:.7rem">
                                    @u.IpAddress
                                </MudText>
                            }
                            @if (_multiSessionIds.Contains(u.Id))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                         Icon="@Icons.Material.Filled.ContentCopy">
                                    Multi-sessió
                                </MudChip>
                            }
                            @if (isSelf)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">Tu</MudChip>
                            }
                        </MudStack>
                    </MudStack>
                    @if (!isSelf && UserState.IsAdmin)
                    {
                        <MudTooltip Text="Tancar sessió">
                            <MudIconButton Icon="@Icons.Material.Filled.ExitToApp"
                                           Size="Size.Small" Color="Color.Error"
                                           OnClick="() => KickAsync(u)" />
                        </MudTooltip>
                    }
                </MudStack>
            </MudCardContent>
        </MudCard>
    };

    private static int RoleOrder(string role) => role switch
    {
        "Admin"     => 0,
        "Gestor"    => 1,
        "Professor" => 2,
        _           => 3
    };

    private static string RelativeTime(long connectedAt)
    {
        var elapsed = DateTimeOffset.UtcNow.ToUnixTimeSeconds() - connectedAt;
        if (elapsed < 60)   return "ara mateix";
        if (elapsed < 3600) return $"fa {elapsed / 60} min";
        var h = elapsed / 3600;
        var m = (elapsed % 3600) / 60;
        return m > 0 ? $"fa {h} h {m} min" : $"fa {h} h";
    }

    private static string RoleLabel(string role) => role switch
    {
        "Admin"     => "Admin",
        "Gestor"    => "Gestor",
        "Professor" => "Professor",
        "Student"   => "Alumne",
        _           => role
    };

    private static Color RoleColor(string role) => role switch
    {
        "Admin"     => Color.Error,
        "Gestor"    => Color.Warning,
        "Professor" => Color.Primary,
        _           => Color.Default
    };

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}".ToUpper()
            : name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }

    private async Task KickAsync(OnlineUserSnapshot u)
    {
        var confirm = await Dialog.ShowMessageBoxAsync("Tancar sessió",
            $"Tancar la sessió de «{u.DisplayName}»?",
            yesText: "Tancar sessió", cancelText: "Cancel·lar");
        if (confirm != true) return;

        var redisDb = Redis.GetDatabase();
        var server  = Redis.GetServer(Redis.GetEndPoints().First());

        // Elimina la clau online de la sessió concreta
        if (u.CircuitId is not null)
        {
            var prefix  = u.Role == "Student" ? "stu" : "prof";
            var onlineKey = $"autoco:online:{prefix}:{u.Id}:{u.CircuitId}";
            await redisDb.KeyDeleteAsync(onlineKey);
        }

        // Invalida els refresh tokens de l'usuari (professor)
        if (u.Role != "Student")
        {
            var refreshKeys = server.Keys(pattern: "autoco:refresh:*");
            foreach (var key in refreshKeys)
            {
                var val = await redisDb.StringGetAsync(key);
                if (val.HasValue && val.ToString().StartsWith($"{u.Id}:"))
                    await redisDb.KeyDeleteAsync(key);
            }
        }

        Snackbar.Add($"Sessió de «{u.DisplayName}» tancada.", Severity.Info);
        await LoadAsync(showSpinner: false);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_timer is not null) await _timer.DisposeAsync();
    }
}
