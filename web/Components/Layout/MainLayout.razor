@inherits LayoutComponentBase
@inject UserStateService UserState
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="3" Dense="true" Style="background:#1e293b">
        <!-- Logo -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Style="min-width:0;flex-shrink:0">
            <MudImage Src="/images/logo2.png" Height="36" Style="display:block" />
        </MudStack>

        <MudSpacer />

        <!-- Usuari + logout -->
        @if (UserState.IsLoggedIn)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Style="min-width:0">
                <MudChip T="string" Size="Size.Small"
                         Style="color:white;background:rgba(255,255,255,.15);flex-shrink:0">
                    @UserState.Role
                </MudChip>
                <MudText Typo="Typo.body2"
                         Style="color:rgba(255,255,255,.9);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px"
                         Class="d-none d-sm-block">
                    @UserState.NomComplet
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               title="@($"Sortir ({UserState.NomComplet})")"
                               OnClick="Logout" />
            </MudStack>
        }
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>

    <!-- Footer fosc, igual que la capçalera -->
    <MudAppBar Bottom="true" Elevation="0" Dense="true" Style="background:#1e293b">
        <MudSpacer />
        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.6)">
            <strong style="color:rgba(255,255,255,.85)">Salesians de Sarrià</strong>
            &nbsp;·&nbsp; Departament d'Informàtica &nbsp;|&nbsp;
            AutoCo Avaluació © @DateTime.Now.Year
        </MudText>
        <MudSpacer />
    </MudAppBar>
</MudLayout>

@code {
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary       = "#CC0000",
            PrimaryDarken = "#a30000",
            Secondary     = "#1e293b",
            SecondaryDarken = "#0f172a",
            AppbarBackground = "#1e293b",
            Background    = "#e2e8f0",
            Surface       = "#ffffff",
            DrawerBackground = "#1e293b",
        }
    };

    private void Logout()
    {
        UserState.Logout();
        Nav.NavigateTo("/", forceLoad: false);
    }
}
