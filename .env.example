# ── Motor de base de dades ───────────────────────────────────────────────────
# DB_PROVIDER=SqlServer    # per defecte; usa el servei "db" (MSSQL) del docker-compose
# DB_PROVIDER=PostgreSQL   # per connectar a PostgreSQL (Docker intern o extern)

# ── Base de dades SQL Server (per defecte) ────────────────────────────────────
MSSQL_SA_PASSWORD=CanviaAquestaContrasenya_2024!

# ── Base de dades PostgreSQL (si DB_PROVIDER=PostgreSQL) ─────────────────────
# POSTGRES_PASSWORD=CanviaAquestaContrasenya_2024!
# Si uses PostgreSQL EXTERN, configura la ConnectionString directament a docker-compose.yml

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CanviaAquestSecret_MiniM32Caracters_2024
JWT_EXPIRY_HOURS=8

# ── Compte administrador ────────────────────────────────────────────────────
ADMIN_PASSWORD=CanviaAquestaContrasenya123!
ADMIN_NOM=Nom
ADMIN_COGNOMS=Cognoms
ADMIN_EMAIL=CorreuElectronic@domini

# ── SMTP (correu) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=el-teu-correu@gmail.com
SMTP_PASSWORD=contrasenya-aplicacio-gmail
SMTP_FROM_ADDRESS=el-teu-correu@gmail.com
SMTP_FROM_NAME=Nom del Centre - Dept. Informàtica

# ── Idioma per defecte i traduccions externes ────────────────────────────────
DEFAULT_LANGUAGE=ca        # ca = català (per defecte), es = castellà, o qualsevol codi de config/i18n/
# I18N_PATH=/app/i18n      # ruta als fitxers JSON de traducció (per defecte /app/i18n, muntat via volum)

# ── Branding corporatiu ───────────────────────────────────────────────────────
# BRAND_APP_NAME=AutoCo Avaluació
# BRAND_APP_SHORT_NAME=AutoCo
# BRAND_ORG_NAME=Salesians de Sarrià
# BRAND_ORG_DEPT=Dept. d'Informàtica
# BRAND_PRIMARY_COLOR=#CC0000    # color primari dels botons i elements destacats
# BRAND_NAV_COLOR=#1e293b        # color de la barra de navegació i el peu de pàgina
# Logo: posar un fitxer logo.png a ./config/branding/ per sobreescriure el logo per defecte

# ── URLs ─────────────────────────────────────────────────────────────────────
APP_WEB_URL=https://localhost

# ── Còpies de seguretat automàtiques ─────────────────────────────────────────
BACKUP_ENABLED=false          # true per activar backups automàtics
BACKUP_DAILY_HOUR=2           # Hora local Europe/Madrid per al backup diari (0-23)
BACKUP_WEEKLY_DAY=0           # Dia de la setmana per al backup setmanal (0=diumenge)
BACKUP_DAILY_RETENTION=7      # Nombre màxim de backups diaris a conservar
BACKUP_WEEKLY_RETENTION=4     # Nombre màxim de backups setmanals a conservar
