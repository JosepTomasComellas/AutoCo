# ==============================================================================
# AutoCo — Configuració d'entorn
# Copia aquest fitxer a ".env" i ajusta els valors abans de desplegar.
# ==============================================================================

# ── Mode de base de dades ─────────────────────────────────────────────────────
#
# ▶ Opció A — MSSQL intern (contenidor Docker, per defecte):
#   COMPOSE_FILE activa docker-compose.db.yml que afegeix el servei "db".
#   DB_CONNECTION ha d'apuntar al host "db" (nom del contenidor).
#   La contrasenya ha de ser la mateixa a MSSQL_SA_PASSWORD i DB_CONNECTION.
#
COMPOSE_FILE=docker-compose.yml:docker-compose.db.yml
MSSQL_SA_PASSWORD=CanviaAquestaContrasenya_2024!
DB_CONNECTION=Server=db;Database=AutoCoAvaluacio;User Id=sa;Password=CanviaAquestaContrasenya_2024!;TrustServerCertificate=True
#
# ▶ Opció B — MSSQL extern (servidor fora del Docker):
#   Elimina o comenta les tres línies anteriors (COMPOSE_FILE, MSSQL_SA_PASSWORD, DB_CONNECTION)
#   i afegeix només DB_CONNECTION apuntant al teu servidor:
#
# DB_CONNECTION=Server=el-teu-servidor\INSTANCIA;Database=AutoCoAvaluacio;User Id=sa;Password=LaContrasenya;TrustServerCertificate=True
#
# ▶ Opció C — PostgreSQL (intern o extern):
#   DB_PROVIDER=PostgreSQL
#   DB_CONNECTION=Host=el-teu-servidor;Database=AutoCoAvaluacio;Username=postgres;Password=LaContrasenya
#   Per PostgreSQL intern en Docker: consulta la documentació (docker-compose.pg.yml pendent).
#
# DB_PROVIDER=SqlServer    # per defecte
# DB_PROVIDER=PostgreSQL   # alternativa

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CanviaAquestSecret_MiniM32Caracters_2024
JWT_EXPIRY_HOURS=8

# ── Compte administrador ────────────────────────────────────────────────────
ADMIN_PASSWORD=CanviaAquestaContrasenya123!
ADMIN_NOM=Nom
ADMIN_COGNOMS=Cognoms
ADMIN_EMAIL=CorreuElectronic@domini

# ── SMTP (correu) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=el-teu-correu@gmail.com
SMTP_PASSWORD=contrasenya-aplicacio-gmail
SMTP_FROM_ADDRESS=el-teu-correu@gmail.com
SMTP_FROM_NAME=Nom del Centre - Dept. Informàtica

# ── Idioma per defecte i traduccions externes ────────────────────────────────
DEFAULT_LANGUAGE=ca        # ca = català (per defecte), es = castellà, o qualsevol codi de config/i18n/
# I18N_PATH=/app/i18n      # ruta als fitxers JSON de traducció (per defecte /app/i18n, muntat via volum)

# ── Branding corporatiu ───────────────────────────────────────────────────────
# BRAND_APP_NAME=AutoCo Avaluació       # nom de l'app al títol del navegador i manifest PWA
# BRAND_APP_SHORT_NAME=AutoCo           # nom curt per al manifest PWA (icona d'escriptori)
# BRAND_ORG_NAME=Salesians de Sarrià   # nom de l'organització al peu de pàgina
# BRAND_ORG_DEPT=Dept. d'Informàtica   # departament al peu de pàgina
# BRAND_PRIMARY_COLOR=#CC0000           # color primari (botons, elements destacats, informes PDF)
# BRAND_NAV_COLOR=#1e293b               # color de la barra de navegació i el peu de pàgina
#
# Fitxers de branding (col·locar a ./config/branding/ — el volum Docker els munta automàticament):
#   logo.png          → sobreescriu el logo per defecte a tota la UI i als informes PDF
#   background.png    → imatge de fons a la pàgina d'inici i pàgines d'autenticació
#   background.jpg    → alternativa JPG per a la imatge de fons (té prioritat .png sobre .jpg)

# ── URLs ─────────────────────────────────────────────────────────────────────
APP_WEB_URL=https://localhost

# ── Còpies de seguretat automàtiques ─────────────────────────────────────────
BACKUP_ENABLED=false          # true per activar backups automàtics
BACKUP_DAILY_HOUR=2           # Hora local Europe/Madrid per al backup diari (0-23)
BACKUP_WEEKLY_DAY=0           # Dia de la setmana per al backup setmanal (0=diumenge)
BACKUP_DAILY_RETENTION=7      # Nombre màxim de backups diaris a conservar
BACKUP_WEEKLY_RETENTION=4     # Nombre màxim de backups setmanals a conservar
